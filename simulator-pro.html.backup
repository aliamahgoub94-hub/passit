// ── STATE ────────────────────────────────────────────────────────────────
const S = {
  std: null, questions: [], idx: 0,
  answers: {}, flags: new Set(),
  secsLeft: 0, timer: null, elapsed: 0,
  hintCache: {}
};

const STD_TIMES = { '32406': 60*60, '32403': 45*60, '32405': 45*60 };
const STD_LABELS = { '32406':'CAA Numeracy — US32406', '32403':'CAA Reading — US32403', '32405':'CAA Writing — US32405' };
const STD_NAMES = { '32406':'CAA Numeracy', '32403':'CAA Reading', '32405':'CAA Writing' };

// ── HELPERS ──────────────────────────────────────────────────────────────
function show(id){ document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function fmtTime(s){ const m=Math.floor(s/60),ss=String(s%60).padStart(2,'0'); return `${m}:${ss}`; }
function wordCount(str){ return str.trim().split(/\s+/).filter(Boolean).length; }

// ── START ────────────────────────────────────────────────────────────────
function startExam(std){
  S.std = std;
  S.isPaid = IS_PAID;
  const allQ = [...BANK[std]].sort(()=>Math.random()-.5);
  S.questions = IS_PAID ? allQ : allQ.slice(0,6);
  S.idx = 0; S.answers = {}; S.flags = new Set(); S.elapsed = 0; S.hintCache = {};
  S.secsLeft = IS_PAID ? STD_TIMES[std] : 99999;
  document.getElementById('topbar-std-label').textContent = STD_LABELS[std] + (IS_PAID ? '' : ' — Free Preview');
  buildNav(); renderQ(0); if(IS_PAID) startTimer(); show('s-exam');
}

function startTimer(){
  clearInterval(S.timer);
  S.timer = setInterval(()=>{
    S.elapsed++;
    S.secsLeft = Math.max(0, STD_TIMES[S.std] - S.elapsed);
    const display = fmtTime(S.secsLeft);
    const el = document.getElementById('timer-val');
    const mob = document.getElementById('mob-timer-val');
    const pill = document.getElementById('timer-pill');
    if(el) el.textContent = display;
    if(mob) mob.textContent = display;
    // mob progress bar
    const pct = Math.min(100, (S.elapsed / STD_TIMES[S.std]) * 100);
    const mobBar = document.getElementById('mob-progress-fill');
    if(mobBar) mobBar.style.width = pct + '%';
    if(pill) pill.className = 'timer-pill' + (S.secsLeft <= 300 ? ' danger' : S.secsLeft <= 600 ? ' warn' : '');
    if(S.secsLeft === 0){ clearInterval(S.timer); submitExam(); }
  }, 1000);
}

// ── NAV ──────────────────────────────────────────────────────────────────
function buildNav(){
  const nav = document.getElementById('q-list');
  const mobNav = document.getElementById('mob-q-list');
  [nav, mobNav].forEach(container => {
    if(!container) return;
    container.innerHTML = '';
    S.questions.forEach((q,i)=>{
      const d = document.createElement('div');
      d.className = 'q-item'; d.id = container===nav ? `qi-${i}` : `mqi-${i}`;
      d.innerHTML = `<div class="q-item-num">${i+1}</div><span class="q-item-text">${q.title}</span><div class="q-flag-dot"></div>`;
      d.onclick = ()=>{ renderQ(i); if(container===mobNav) document.getElementById('mob-drawer').classList.remove('open'); };
      container.appendChild(d);
    });
  });
  updateNav();
}

function updateNav(){
  const answered = S.questions.filter(q=>S.answers[q.id]!==undefined && S.answers[q.id]!=='').length;
  const prog = document.getElementById('sb-progress');
  if(prog) prog.textContent = `${answered}/${S.questions.length}`;
  S.questions.forEach((q,i)=>{
    const isActive = i===S.idx;
    const isAnswered = S.answers[q.id]!==undefined && S.answers[q.id]!=='';
    const isFlagged = S.flags.has(q.id);
    const cls = ['q-item', isActive&&'is-active', isAnswered&&'is-answered', isFlagged&&'is-flagged'].filter(Boolean).join(' ');
    const item = document.getElementById(`qi-${i}`);
    const mitem = document.getElementById(`mqi-${i}`);
    if(item) item.className = cls;
    if(mitem) mitem.className = cls;
  });
  const q = S.questions[S.idx];
  if(q){
    const sl = document.getElementById('sb-section');
    const msl = document.getElementById('mob-section-label');
    if(sl) sl.textContent = q.sec;
    if(msl) msl.textContent = q.sec;
  }
}

// ── RENDER ───────────────────────────────────────────────────────────────
function renderQ(idx){
  S.idx = idx;
  const q = S.questions[idx];
  const panel = document.getElementById('q-panel');
  const sa = S.answers[q.id] ?? '';
  const isFlagged = S.flags.has(q.id);

  // Task input HTML
  let inputHTML = '';
  if(q.type==='currency'){
    inputHTML = `
      <label class="inp-label">Your Answer ($)</label>
      <div class="cur-wrap">
        <span class="cur-sym">$</span>
        <input type="number" step="0.01" min="0" class="inp-number has-prefix" id="ans-inp" placeholder="0.00" value="${sa}" oninput="saveAns()">
      </div>
      <div class="working-box">
        <label class="inp-label">Show your working (optional)</label>
        <textarea class="inp-textarea" id="work-inp" rows="3" placeholder="Write your steps here…" oninput="saveWork()">${S.answers[q.id+'_w']||''}</textarea>
      </div>`;
  } else if(q.type==='number'){
    inputHTML = `
      <label class="inp-label">Your Answer</label>
      <input type="number" class="inp-number" id="ans-inp" placeholder="Enter a number" value="${sa}" oninput="saveAns()" style="margin-bottom:14px">
      <div class="working-box">
        <label class="inp-label">Show your working (optional)</label>
        <textarea class="inp-textarea" id="work-inp" rows="3" placeholder="Write your steps here…" oninput="saveWork()">${S.answers[q.id+'_w']||''}</textarea>
      </div>`;
  } else if(q.type==='mc'){
    inputHTML = `<div class="mc-list">` +
      q.options.map(opt=>`<div class="mc-opt ${sa===opt?'sel':''}" onclick="pickMC(this,'${opt.replace(/'/g,"\\'")}')"><div class="mc-radio"></div><span class="mc-opt-text">${opt}</span></div>`).join('') +
      `</div>`;
  } else if(q.type==='writing'){
    const wc = sa ? wordCount(sa) : 0;
    inputHTML = `
      <div class="rubric-box">
        <div class="rubric-title">Assessment criteria</div>
        <ul class="rubric-list">${q.rubric.map(r=>`<li class="rubric-item">${r}</li>`).join('')}</ul>
      </div>
      <label class="inp-label">Your Response</label>
      <textarea class="inp-textarea" id="ans-inp" rows="9" placeholder="Write your response here…" oninput="saveAns();updateWC()" style="min-height:170px">${sa}</textarea>
      <div class="wc-row">
        <span class="wc-label">${q.wordMin}–${q.wordMax} words</span>
        <span class="wc-count ${wc>=q.wordMin&&wc<=q.wordMax?'ok':''}" id="wc-display">${wc} words</span>
      </div>
      <div class="ai-writing-fb" id="ai-write-fb">
        <div class="ai-writing-fb-head">✦ AI Marking</div>
        <div id="ai-criteria-rows"></div>
        <div class="ai-overall" id="ai-overall"></div>
      </div>`;
  }

  // Passage
  const passageHTML = q.passage ? `
    <div class="passage">
      <div class="passage-title">${q.passageTitle||'Read the following text'}</div>
      <div class="passage-body">${q.passage.replace(/\n/g,'<br>')}</div>
    </div>` : '';

  panel.innerHTML = `
    <div class="std-${S.std}">
      <div class="q-card">
        <div class="q-card-stripe"></div>
        <div class="q-card-body">
          <div class="q-meta">
            <span class="q-meta-badge badge-num">Question ${idx+1} of ${S.questions.length}</span>
            <span class="q-meta-badge badge-sec">${q.sec}</span>
            <button class="q-flag-btn ${isFlagged?'flagged':''}" id="flag-btn" onclick="toggleFlag()">
              ${isFlagged?'⚑ Flagged':'⚐ Flag for review'}
            </button>
            <span class="q-emoji">${q.emoji}</span>
          </div>
          <h2 class="q-title">${q.title}</h2>
          ${passageHTML}
          ${q.scenario?`<p class="q-scenario">${q.scenario}</p>`:''}
          ${q.callout?`<div class="q-callout">${q.callout}</div>`:''}
          <span class="q-task-label">${q.task}</span>
          ${inputHTML}
          <div class="feedback" id="feedback"></div>
        </div>
        <div class="q-nav-row">
          <button class="btn-nav" onclick="goQ(${idx-1})" ${idx===0?'disabled':''}>← Previous</button>
          <button class="btn-nav btn-check" onclick="checkAnswer()">✦ Check Answer</button>
          <button class="btn-nav primary" onclick="goQ(${idx+1})" ${idx===S.questions.length-1?'disabled':''}>Next →</button>
        </div>
      </div>
    </div>`;

  updateNav();
  loadHint(q);
  panel.scrollTop = 0;
}

function goQ(i){ if(i>=0 && i<S.questions.length) renderQ(i); }

function toggleFlag(){
  const q = S.questions[S.idx];
  if(S.flags.has(q.id)) S.flags.delete(q.id); else S.flags.add(q.id);
  const btn = document.getElementById('flag-btn');
  if(btn){ btn.className='q-flag-btn '+(S.flags.has(q.id)?'flagged':''); btn.textContent=S.flags.has(q.id)?'⚑ Flagged':'⚐ Flag for review'; }
  updateNav();
}

// ── ANSWER SAVE ──────────────────────────────────────────────────────────
function saveAns(){
  const q=S.questions[S.idx]; const inp=document.getElementById('ans-inp'); if(!inp)return;
  const v=inp.value.trim();
  S.answers[q.id] = (q.type==='currency'||q.type==='number') ? (v?parseFloat(v):'') : v;
  updateNav();
}
function saveWork(){ const q=S.questions[S.idx]; const inp=document.getElementById('work-inp'); if(inp)S.answers[q.id+'_w']=inp.value; }
function updateWC(){
  const inp=document.getElementById('ans-inp'); const el=document.getElementById('wc-display'); if(!inp||!el)return;
  const q=S.questions[S.idx]; const wc=wordCount(inp.value);
  el.textContent=`${wc} words`; el.className='wc-count '+(wc>=q.wordMin&&wc<=q.wordMax?'ok':'');
}
function pickMC(el,val){
  document.querySelectorAll('.mc-opt').forEach(o=>o.classList.remove('sel')); el.classList.add('sel');
  S.answers[S.questions[S.idx].id]=val; updateNav();
}

// ── CHECK ────────────────────────────────────────────────────────────────
async function checkAnswer(){
  saveAns();
  const q=S.questions[S.idx]; const ua=S.answers[q.id]; const fb=document.getElementById('feedback');
  if(ua===undefined||ua===''){
    fb.className='feedback show err'; fb.innerHTML='<div class="feedback-label">⚠ No answer yet</div>Enter your answer before checking.'; return;
  }
  if(q.type==='writing'){
    const wc=wordCount(String(ua));
    if(wc<q.wordMin){
      fb.className='feedback show err'; fb.innerHTML=`<div class="feedback-label">✗ Too short (${wc} words)</div>Aim for at least ${q.wordMin} words. Tip: ${q.hint}`; return;
    }
    // AI marking
    fb.className='feedback show ok'; fb.innerHTML='<div class="feedback-label">✦ Sending to AI marker…</div>';
    await markWritingWithAI(q, String(ua));
    return;
  }
  let correct=false;
  if(q.type==='mc') correct=ua===q.answer;
  else correct=Math.abs(Number(ua)-Number(q.answer))<=(q.tol??0);

  fb.className=`feedback show ${correct?'ok':'err'}`;
  if(correct) fb.innerHTML=`<div class="feedback-label">✓ Correct!</div>${q.explain}`;
  else{
    const disp=q.type==='currency'?`$${Number(q.answer).toFixed(2)}`:q.answer;
    fb.innerHTML=`<div class="feedback-label">✗ Not quite — correct answer: ${disp}</div>${q.explain}`;
  }
}

// ── AI MARKING (Writing) ─────────────────────────────────────────────────
async function markWritingWithAI(q, response){
  const fb = document.getElementById('feedback');
  const aiFb = document.getElementById('ai-write-fb');
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:600,
        system:`You are an NCEA NZ writing assessor. Given a student's response and a rubric, return ONLY valid JSON in this exact format:
{"criteria":[{"name":"criterion name","verdict":"met"|"partial"|"missing","note":"one short sentence max"}],"overall":"One sentence overall feedback, specific and constructive."}
Be honest but encouraging. Use NZ English.`,
        messages:[{role:'user',content:`Task: ${q.task}\nRubric criteria: ${q.rubric.join(', ')}\nStudent response:\n${response}`}]
      })
    });
    const data = await res.json();
    const text = data?.content?.[0]?.text ?? '';
    const json = JSON.parse(text.replace(/```json|```/g,'').trim());

    // Render criteria rows
    const rows = json.criteria.map(c=>{
      const cls = c.verdict==='met'?'cb-met':c.verdict==='partial'?'cb-partial':'cb-miss';
      const label = c.verdict==='met'?'✓ Met':c.verdict==='partial'?'~ Partial':'✗ Missing';
      return `<div class="criterion-row"><span class="criterion-name">${c.name}</span><span class="criterion-badge ${cls}">${label}</span></div>${c.note?`<div style="font-size:.75rem;color:var(--ink-3);padding:3px 0 6px">${c.note}</div>`:''}`;
    }).join('');

    if(aiFb){
      aiFb.className='ai-writing-fb show';
      document.getElementById('ai-criteria-rows').innerHTML=rows;
      document.getElementById('ai-overall').innerHTML=`<strong>Overall:</strong> ${json.overall}`;
    }
    fb.className='feedback show ok';
    fb.innerHTML=`<div class="feedback-label">✓ AI marking complete</div>See the detailed breakdown below.`;
  } catch(e){
    fb.className='feedback show ok';
    fb.innerHTML=`<div class="feedback-label">✓ Response submitted (${wordCount(response)} words)</div>${q.explain}<br><br>Check your response against the rubric above.`;
  }
}

// ── AI HINT ──────────────────────────────────────────────────────────────
async function loadHint(q){
  const el=document.getElementById('ai-hint');
  const mob=document.getElementById('mob-ai-hint');
  const setHint = (text) => { if(el) el.textContent=text; if(mob) mob.textContent=text; };
  const setLoading = () => {
    const dots = '<div class="ai-dots"><div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div></div>';
    if(el) el.innerHTML=dots; if(mob) mob.innerHTML=dots;
  };
  if(!el && !mob) return;
  if(!IS_PAID){ setHint('🔒 AI hints are included in full access. Get access at passit.co.nz'); return; }
  if(S.hintCache[q.id]){ setHint(S.hintCache[q.id]); return; }
  if(q.hint){ S.hintCache[q.id]=q.hint; setHint(q.hint); return; }
  setLoading();
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:100,system:'One short NZ NCEA coaching hint (max 2 sentences). Point to method, not answer. Start directly.',messages:[{role:'user',content:`${q.task} Context: ${(q.scenario||'')+(q.callout||'')}`.replace(/<[^>]+>/g,'')}]})});
    const d=await r.json(); const h=d?.content?.[0]?.text??q.hint??'Think step by step.';
    S.hintCache[q.id]=h; setHint(h);
  }catch{ setHint(q.hint??'Think step by step.'); }
}

// ── SUBMIT ───────────────────────────────────────────────────────────────
function submitExam(){
  clearInterval(S.timer);
  const qs=S.questions; let correct=0,scoreable=0;
  qs.forEach(q=>{
    if(q.type==='writing')return; scoreable++;
    const ua=S.answers[q.id]; if(ua===undefined||ua==='')return;
    if(q.type==='mc'){if(ua===q.answer)correct++;}
    else{if(Math.abs(Number(ua)-Number(q.answer))<=(q.tol??0))correct++;}
  });
  const pct = scoreable>0?Math.round(correct/scoreable*100):0;
  const elapsed = S.elapsed;
  const m=Math.floor(elapsed/60), ss=String(elapsed%60).padStart(2,'0');

  // Readiness level
  let rdLabel,rdClass,rdSub;
  if(pct>=80){rdLabel='✓ CAA-Ready';rdClass='rb-ready';rdSub='Strong performance — you\'re on track to achieve this standard.';}
  else if(pct>=55){rdLabel='◑ Developing';rdClass='rb-developing';rdSub='You\'re building the right skills. Target the gaps below.';}
  else{rdLabel='✗ Not Yet Ready';rdClass='rb-not-ready';rdSub='Keep practising — the gap report below shows exactly where to focus.';}

  document.getElementById('readiness-badge').className=`readiness-badge ${rdClass}`;
  document.getElementById('readiness-badge').textContent=rdLabel;
  document.getElementById('results-sub').textContent=rdSub;
  document.getElementById('res-std-name').textContent=STD_NAMES[S.std];
  document.getElementById('ring-pct').textContent=scoreable>0?`${pct}%`:'N/A';
  document.getElementById('st-correct').textContent=scoreable>0?`${correct}/${scoreable}`:'—';
  document.getElementById('st-total').textContent=qs.length;
  document.getElementById('st-time').textContent=`${m}:${ss}`;
  document.getElementById('res-breakdown').textContent=S.std==='32405'
    ?'Writing tasks are AI-marked — review your criterion feedback above.'
    :pct>=80?`${correct} of ${scoreable} correct — excellent work.`:`${correct} of ${scoreable} correct — see gap report below.`;

  // Animate ring
  setTimeout(()=>{
    const fill=document.getElementById('ring-fill');
    fill.style.stroke=pct>=80?'var(--green)':pct>=55?'var(--amber)':'var(--red)';
    fill.style.strokeDashoffset=scoreable>0?String(264-(264*pct/100)):'264';
  },100);

  // Gap report
  buildGapReport(qs);

  // ── CAN I PASS YET METER ──
  // Save session to history
  const sessionData = { ts: Date.now(), std: S.std, pct: pct };
  const history = JSON.parse(localStorage.getItem('passit_sessions') || '[]');
  history.push(sessionData);
  if(history.length > 10) history.shift();
  localStorage.setItem('passit_sessions', JSON.stringify(history));

  // Calculate readiness across all standards
  const allSessions = JSON.parse(localStorage.getItem('passit_sessions') || '[]');
  const byStd = { '32403':[], '32405':[], '32406':[] };
  allSessions.forEach(s => { if(byStd[s.std]) byStd[s.std].push(s.pct); });

  // Average last 3 sessions per standard, weight recent ones more
  function getStdScore(sessions){
    if(!sessions.length) return null;
    const recent = sessions.slice(-3);
    return Math.round(recent.reduce((a,b,i)=>a+b*(i+1),0) / recent.reduce((_,__,i)=>_ + i+1,0));
  }

  const scores = {
    '32403': getStdScore(byStd['32403']),
    '32405': getStdScore(byStd['32405']),
    '32406': getStdScore(byStd['32406'])
  };

  const available = Object.values(scores).filter(s=>s!==null);
  if(available.length > 0){
    const overall = Math.round(available.reduce((a,b)=>a+b,0)/available.length);
    const meter = document.getElementById('pass-meter');
    if(meter) meter.style.display = 'block';

    setTimeout(()=>{
      const fill = document.getElementById('cipy-fill');
      const pctEl = document.getElementById('cipy-pct');
      if(fill){ fill.style.stroke = overall>=75?'#00a86b':overall>=50?'#d97706':'#dc2626'; fill.style.strokeDashoffset = String(314-(314*overall/100)); }
      if(pctEl) pctEl.textContent = overall+'%';

      let title, desc;
      if(overall>=75){ title='Looking good!'; desc='Based on your recent sessions, you are on track to achieve the co-requisite. Keep up this level of practice.'; }
      else if(overall>=50){ title='Getting closer'; desc='You are making progress. A few more focused practice sessions will significantly improve your readiness.'; }
      else { title='More practice needed'; desc='Your scores show you need more practice before your exam window. Focus on the gaps in your report below.'; }

      const t = document.getElementById('cipy-title');
      const d = document.getElementById('cipy-desc');
      const h = document.getElementById('cipy-history');
      if(t) t.textContent = title;
      if(d) d.textContent = desc;

      // Show session history dots
      if(h){
        const stdNames = {'32403':'Reading','32405':'Writing','32406':'Numeracy'};
        h.innerHTML = Object.entries(scores).filter(([k,v])=>v!==null).map(([k,v])=>
          `<span class="cipy-session">${stdNames[k]}: ${v}%</span>`
        ).join('');
      }
    }, 400);
  }

  show('s-results');
  window.scrollTo(0,0);
  // Show upgrade banner for free users
  const banner = document.getElementById('free-upgrade-banner');
  if(banner) banner.style.display = S.isPaid ? 'none' : 'block';
}

function buildGapReport(qs){
  const list=document.getElementById('gap-list'); list.innerHTML='';
  const locked=document.getElementById('gap-locked');
  if(!S.isPaid){ list.style.display='none'; if(locked) locked.style.display='block'; return; }
  if(locked) locked.style.display='none'; list.style.display='block';
  qs.forEach(q=>{
    let status='ok';
    if(q.type==='writing'){
      const ua=S.answers[q.id];
      status=(!ua||wordCount(String(ua))<(q.wordMin||40))?'miss':'ok';
    } else {
      const ua=S.answers[q.id];
      if(ua===undefined||ua==='') status='miss';
      else if(q.type==='mc') status=ua===q.answer?'ok':'miss';
      else status=Math.abs(Number(ua)-Number(q.answer))<=(q.tol??0)?'ok':'miss';
    }
    const icons={ok:'✓',miss:'✗',partial:'~'};
    const row=document.createElement('div'); row.className='gap-row';
    row.innerHTML=`
      <div class="gap-icon ${status}">${icons[status]}</div>
      <div class="gap-body">
        <div class="gap-topic">${q.topic}</div>
        <div class="gap-boost">${status==='ok'
          ?`<strong>Strong.</strong> ${q.boost}`
          :`<strong>Boost task:</strong> ${q.boost}`}</div>
      </div>`;
    list.appendChild(row);
  });
}

function retryExam(){ startExam(S.std); }
function goHome(){
  clearInterval(S.timer);
  window.location='/';
}

// ── ACCESS GATE ──────────────────────────────────────────────────────────
const VALID_CODES = ['PASSIT2026','NCEA2026','PASSITCAA','EARLYBIRD'];
let IS_PAID = false;

function checkCode(){
  const input = document.getElementById('gate-code-input').value.trim().toUpperCase();
  const err = document.getElementById('gate-error');
  if(VALID_CODES.includes(input)){
    localStorage.setItem('passit_access','granted');
    IS_PAID = true;
    document.getElementById('access-gate').classList.add('hidden');
    err.style.display='none';
  } else {
    err.style.display='block';
    document.getElementById('gate-code-input').value='';
    document.getElementById('gate-code-input').focus();
  }
}

function startFree(){
  IS_PAID = false;
  document.getElementById('access-gate').classList.add('hidden');
}

// Check access on load
(function(){
  const granted = localStorage.getItem('passit_access') === 'granted';
  if(granted){ IS_PAID = true; document.getElementById('access-gate').classList.add('hidden'); }
})();

</script>
<script>

// GATE
var CODES = ['PASSIT2026','NCEA2026','PASSITCAA','EARLYBIRD'];
function doUnlock(){
  var inp = document.getElementById('gi');
  var err = document.getElementById('ge');
  var gate = document.getElementById('gate');
  if(!inp || !gate) return;
  var v = inp.value.toUpperCase().trim();
  if(CODES.indexOf(v) !== -1){
    IS_PAID = true;
    localStorage.setItem('paa','1');
    gate.classList.add('off');
    err.style.display = 'none';
  } else {
    err.style.display = 'block';
    inp.value = '';
    inp.focus();
  }
}
document.addEventListener('keydown', function(ev){
  if(ev.key === 'Enter') doUnlock();
});
// Show gate - always visible until correct code entered
(function(){
  var g = document.getElementById('gate');
  if(g) g.style.display = 'flex';
})();

</script>
</body>
</html>
