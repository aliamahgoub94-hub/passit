<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Passit — CAA Practice Simulator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #12100e;
  --ink-2: #4a4540;
  --ink-3: #9a928a;
  --paper: #f7f4f0;
  --paper-2: #efecea;
  --paper-3: #e5e0d8;
  --surface: #ffffff;
  --navy: #1c3557;
  --navy-mid: #2d5080;
  --navy-light: #eef2f8;
  --gold: #c08a28;
  --gold-light: #fdf5e4;
  --green: #1a6040;
  --green-light: #ebf5ef;
  --red: #aa3428;
  --red-light: #fdf0ee;
  --amber: #c47a18;
  --r: 14px;
  --shadow: 0 2px 12px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.04);
  --shadow-lg: 0 8px 32px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.05);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased}

/* ─── SCREENS ─── */
.screen{display:none}
.screen.active{display:flex}

/* ─── LANDING ─── */
#s-landing{
  min-height:100vh;flex-direction:column;align-items:center;justify-content:center;
  padding:48px 20px;background:var(--paper);
  background-image:radial-gradient(circle at 70% 20%, rgba(28,53,87,.05) 0%, transparent 55%),
                   radial-gradient(circle at 20% 80%, rgba(192,138,40,.06) 0%, transparent 50%);
}
.landing-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--navy-light);color:var(--navy);
  font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:5px 14px;border-radius:40px;border:1px solid #c8d8ee;
  margin-bottom:28px;
}
.landing-logo{
  font-family:'Fraunces',serif;font-size:3.2rem;font-weight:700;
  color:var(--navy);letter-spacing:-2px;line-height:1;margin-bottom:8px;
}
.landing-logo em{font-style:italic;color:var(--gold)}
.landing-sub{color:var(--ink-2);font-size:1.05rem;font-weight:300;margin-bottom:56px;text-align:center}

.std-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;max-width:860px;width:100%;margin-bottom:40px}
@media(max-width:700px){.std-grid{grid-template-columns:1fr}}

.std-tile{
  background:var(--surface);border:1.5px solid var(--paper-3);
  border-radius:var(--r);padding:24px 22px;cursor:pointer;
  transition:all .2s ease;position:relative;overflow:hidden;
}
.std-tile:hover{border-color:var(--navy-mid);box-shadow:var(--shadow-lg);transform:translateY(-3px)}
.std-tile-bar{position:absolute;top:0;left:0;right:0;height:3px}
.std-tile[data-s="32403"] .std-tile-bar{background:#3d80cc}
.std-tile[data-s="32405"] .std-tile-bar{background:var(--green)}
.std-tile[data-s="32406"] .std-tile-bar{background:var(--gold)}

.std-tile-code{font-family:'DM Mono',monospace;font-size:.68rem;color:var(--ink-3);letter-spacing:.06em;margin-bottom:10px}
.std-tile-name{font-family:'Fraunces',serif;font-size:1.4rem;font-weight:600;margin-bottom:6px}
.std-tile-credits{
  display:inline-flex;align-items:center;gap:4px;
  background:var(--navy-light);color:var(--navy);
  font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:14px
}
.std-tile-desc{font-size:.83rem;color:var(--ink-2);line-height:1.65;margin-bottom:20px}
.std-tile-cta{
  width:100%;padding:10px;background:var(--navy);color:#fff;
  border:none;border-radius:9px;font-family:'DM Sans',sans-serif;
  font-size:.83rem;font-weight:600;cursor:pointer;transition:background .15s
}
.std-tile-cta:hover{background:var(--navy-mid)}

.landing-foot{
  max-width:580px;text-align:center;font-size:.78rem;color:var(--ink-3);
  line-height:1.8;padding:14px 20px;border:1px solid var(--paper-3);
  border-radius:var(--r);background:var(--surface)
}

/* ─── EXAM SHELL ─── */
#s-exam{flex-direction:column;height:100vh;overflow:hidden}

.exam-topbar{
  height:54px;background:var(--navy);display:flex;align-items:center;
  justify-content:space-between;padding:0 20px;flex-shrink:0;z-index:20
}
.topbar-left{display:flex;align-items:center;gap:14px}
.topbar-logo{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:600;color:#fff;letter-spacing:-.5px}
.topbar-logo em{font-style:italic;color:#f0c060}
.topbar-std{font-size:.75rem;color:rgba(255,255,255,.5);padding-left:14px;border-left:1px solid rgba(255,255,255,.15)}
.topbar-right{display:flex;align-items:center;gap:14px}

.timer-pill{
  display:flex;align-items:center;gap:7px;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);
  border-radius:8px;padding:5px 13px;
}
.timer-icon{width:13px;height:13px;opacity:.6}
.timer-val{font-family:'DM Mono',monospace;font-size:.95rem;font-weight:500;color:#fff;letter-spacing:.04em}
.timer-pill.warn .timer-val{color:#ffc947}
.timer-pill.danger .timer-val{color:#ff7070}

.submit-btn{
  background:#22c55e;color:#fff;border:none;border-radius:8px;
  padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.8rem;
  font-weight:700;cursor:pointer;transition:background .15s
}
.submit-btn:hover{background:#16a34a}

.exam-body{display:flex;flex:1;overflow:hidden}

/* ─── SIDEBAR ─── */
.sidebar{
  width:252px;flex-shrink:0;background:var(--surface);
  border-right:1px solid var(--paper-3);display:flex;flex-direction:column;overflow:hidden
}
.sb-head{
  padding:12px 14px;border-bottom:1px solid var(--paper-3);
  display:flex;justify-content:space-between;align-items:center
}
.sb-head-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--ink-3)}
.sb-progress{font-size:.7rem;font-weight:700;color:var(--navy);background:var(--navy-light);padding:2px 8px;border-radius:20px}

.q-list{flex:1;overflow-y:auto;padding:6px}
.q-item{
  display:flex;align-items:center;gap:8px;padding:9px 10px;
  border-radius:9px;cursor:pointer;transition:all .12s;margin-bottom:2px;
  border-left:2px solid transparent;
}
.q-item:hover{background:var(--paper)}
.q-item.is-active{background:var(--navy-light);border-left-color:var(--navy)}
.q-item.is-answered{background:var(--green-light)}
.q-item.is-active.is-answered{background:var(--navy-light)}
.q-item.is-flagged{background:#fff8ec;border-left-color:var(--gold)}

.q-item-num{
  width:22px;height:22px;border-radius:50%;border:1.5px solid var(--paper-3);
  flex-shrink:0;display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:700;color:var(--ink-3);transition:all .12s
}
.q-item.is-active .q-item-num{border-color:var(--navy);background:var(--navy);color:#fff}
.q-item.is-answered .q-item-num{border-color:var(--green);background:var(--green);color:#fff}
.q-item.is-answered .q-item-num::after{content:'✓'}
.q-item.is-answered:not(.is-active) .q-item-num{font-size:0}
.q-item.is-flagged .q-item-num{border-color:var(--gold);background:var(--gold-light);color:var(--gold)}

.q-item-text{font-size:.78rem;color:var(--ink-2);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.q-item.is-active .q-item-text{color:var(--navy);font-weight:600}
.q-flag-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0;display:none}
.q-item.is-flagged .q-flag-dot{display:block}

/* AI Hint */
.ai-box{
  margin:10px;border-radius:var(--r);
  background:var(--gold-light);border:1px solid #e8d080;padding:13px
}
.ai-box-head{
  display:flex;align-items:center;gap:5px;
  font-size:.65rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.09em;color:var(--gold);margin-bottom:7px
}
.ai-box-text{font-size:.78rem;color:#5a3c08;line-height:1.65}
.ai-dots{display:flex;gap:3px;padding:4px 0}
.ai-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);animation:pulse 1.3s infinite ease-in-out}
.ai-dot:nth-child(2){animation-delay:.2s}
.ai-dot:nth-child(3){animation-delay:.4s}
@keyframes pulse{0%,80%,100%{transform:translateY(0);opacity:.3}40%{transform:translateY(-5px);opacity:1}}

/* ─── QUESTION PANEL ─── */
.q-panel{flex:1;overflow-y:auto;padding:28px 32px;background:var(--paper)}

.q-card{
  max-width:720px;margin:0 auto;background:var(--surface);
  border:1px solid var(--paper-3);border-radius:18px;overflow:hidden;box-shadow:var(--shadow)
}
.q-card-stripe{height:4px}
.std-32403 .q-card-stripe{background:#3d80cc}
.std-32405 .q-card-stripe{background:var(--green)}
.std-32406 .q-card-stripe{background:var(--gold)}

.q-card-body{padding:32px 36px}

.q-meta{display:flex;align-items:center;gap:8px;margin-bottom:18px}
.q-meta-badge{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:3px 10px;border-radius:20px}
.badge-num{background:var(--navy-light);color:var(--navy)}
.badge-sec{background:var(--paper);color:var(--ink-3);border:1px solid var(--paper-3)}
.q-flag-btn{
  margin-left:auto;display:flex;align-items:center;gap:5px;
  font-size:.72rem;font-weight:600;color:var(--ink-3);
  background:none;border:1.5px solid var(--paper-3);border-radius:7px;
  padding:4px 10px;cursor:pointer;transition:all .15s
}
.q-flag-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-light)}
.q-flag-btn.flagged{border-color:var(--gold);color:var(--gold);background:var(--gold-light)}
.q-emoji{font-size:2.2rem;margin-left:8px}

.q-title{font-family:'Fraunces',serif;font-size:1.45rem;font-weight:600;color:var(--ink);line-height:1.3;margin-bottom:12px}

/* Passage */
.passage{
  background:var(--paper);border:1px solid var(--paper-3);
  border-radius:11px;padding:18px 22px;margin-bottom:20px;
}
.passage-title{font-family:'Fraunces',serif;font-size:.95rem;font-weight:600;margin-bottom:10px;color:var(--ink)}
.passage-body{font-size:.85rem;color:var(--ink);line-height:1.85}

.q-scenario{font-size:.95rem;color:var(--ink-2);line-height:1.75;margin-bottom:8px}
.q-scenario strong{color:var(--ink);font-weight:600}
.q-callout{
  border-left:3px solid var(--paper-3);padding:9px 16px;
  margin:14px 0;font-size:.88rem;color:var(--ink-2);
  font-style:italic;background:var(--paper);border-radius:0 8px 8px 0
}
.q-callout strong{color:var(--ink);font-style:normal}

.q-task-label{
  font-size:.72rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.08em;color:var(--ink-3);margin:22px 0 10px;
  padding-top:20px;border-top:1px solid var(--paper-3);display:block
}

/* Inputs */
.inp-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-3);display:block;margin-bottom:7px}
.cur-wrap{position:relative;margin-bottom:16px}
.cur-sym{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-family:'DM Mono',monospace;font-size:.95rem;color:var(--ink-3);pointer-events:none}
.inp-number{
  width:100%;background:var(--paper);border:2px solid var(--paper-3);
  border-radius:10px;padding:13px 14px;font-family:'DM Mono',monospace;
  font-size:1.1rem;color:var(--ink);outline:none;transition:border-color .15s
}
.inp-number.has-prefix{padding-left:34px}
.inp-number:focus{border-color:var(--navy);background:#fff}
.inp-textarea{
  width:100%;background:var(--paper);border:2px solid var(--paper-3);
  border-radius:10px;padding:13px 14px;font-family:'DM Sans',sans-serif;
  font-size:.88rem;color:var(--ink);outline:none;resize:vertical;
  min-height:90px;line-height:1.65;transition:border-color .15s
}
.inp-textarea:focus{border-color:var(--navy);background:#fff}

.working-box{background:var(--navy-light);border:1.5px solid #c8d8ee;border-radius:10px;padding:14px;margin-top:14px}
.working-box .inp-label{color:var(--navy-mid)}
.working-box .inp-textarea{background:#fff}

/* MC */
.mc-list{display:flex;flex-direction:column;gap:9px}
.mc-opt{
  display:flex;align-items:flex-start;gap:11px;padding:13px 15px;
  border:2px solid var(--paper-3);border-radius:10px;cursor:pointer;
  background:var(--paper);transition:all .15s
}
.mc-opt:hover{border-color:var(--navy-mid);background:var(--navy-light)}
.mc-opt.sel{border-color:var(--navy);background:var(--navy-light)}
.mc-radio{
  width:19px;height:19px;border-radius:50%;border:2px solid var(--paper-3);
  flex-shrink:0;margin-top:2px;transition:all .15s;display:flex;align-items:center;justify-content:center
}
.mc-opt.sel .mc-radio{border-color:var(--navy);background:var(--navy)}
.mc-opt.sel .mc-radio::after{content:'';width:7px;height:7px;border-radius:50%;background:#fff}
.mc-opt-text{font-size:.88rem;color:var(--ink);line-height:1.5}

/* Writing rubric */
.rubric-box{background:var(--gold-light);border:1px solid #e8d080;border-radius:10px;padding:14px;margin-bottom:14px}
.rubric-title{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--gold);margin-bottom:8px}
.rubric-list{list-style:none;display:flex;flex-direction:column;gap:4px}
.rubric-item{font-size:.78rem;color:#5a3c08;display:flex;align-items:center;gap:6px}
.rubric-item::before{content:'◦';color:var(--gold);flex-shrink:0}
.wc-row{display:flex;justify-content:space-between;margin-top:6px}
.wc-label{font-size:.72rem;color:var(--ink-3)}
.wc-count{font-size:.72rem;color:var(--ink-3)}
.wc-count.ok{color:var(--green)}

/* Feedback */
.feedback{display:none;margin-top:16px;border-radius:10px;padding:13px 15px;font-size:.85rem;line-height:1.65}
.feedback.show{display:block}
.feedback.ok{background:var(--green-light);border:1px solid #a8d5bc;color:var(--green)}
.feedback.err{background:var(--red-light);border:1px solid #e5b8b2;color:var(--red)}
.feedback-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;display:flex;align-items:center;gap:5px}

/* AI writing feedback */
.ai-writing-fb{display:none;margin-top:14px;background:var(--navy-light);border:1px solid #c8d8ee;border-radius:10px;padding:14px}
.ai-writing-fb.show{display:block}
.ai-writing-fb-head{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--navy);margin-bottom:10px;display:flex;align-items:center;gap:5px}
.criterion-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid #dce8f5;font-size:.8rem}
.criterion-row:last-child{border-bottom:none}
.criterion-name{color:var(--ink-2)}
.criterion-badge{font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:20px}
.cb-met{background:var(--green-light);color:var(--green);border:1px solid #a8d5bc}
.cb-partial{background:#fff8ec;color:var(--amber);border:1px solid #e8d080}
.cb-miss{background:var(--red-light);color:var(--red);border:1px solid #e5b8b2}
.ai-overall{margin-top:10px;padding-top:10px;border-top:1px solid #dce8f5;font-size:.82rem;color:var(--ink-2);line-height:1.65}

/* Nav btns */
.q-nav-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 36px;border-top:1px solid var(--paper-3);background:var(--surface)
}
.btn-nav{
  display:flex;align-items:center;gap:6px;padding:9px 18px;
  border-radius:9px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;
  cursor:pointer;transition:all .15s;border:1.5px solid var(--paper-3);
  background:var(--surface);color:var(--ink-2)
}
.btn-nav:hover{border-color:var(--navy);color:var(--navy);background:var(--navy-light)}
.btn-nav:disabled{opacity:.3;pointer-events:none}
.btn-nav.primary{background:var(--navy);color:#fff;border-color:var(--navy)}
.btn-nav.primary:hover{background:var(--navy-mid)}
.btn-check{background:var(--gold-light);border-color:#e0c060;color:var(--gold)}
.btn-check:hover{background:#fbedc0;color:#8a6010;border-color:var(--gold)}

/* ─── RESULTS ─── */
#s-results{
  min-height:100vh;flex-direction:column;align-items:center;
  justify-content:flex-start;padding:60px 20px;background:var(--paper)
}
.results-wrap{max-width:640px;width:100%}

.results-logo{font-family:'Fraunces',serif;font-size:1.8rem;font-weight:600;color:var(--navy);text-align:center;margin-bottom:4px}
.results-logo em{font-style:italic;color:var(--gold)}

.readiness-badge{
  display:inline-flex;align-items:center;gap:7px;
  padding:10px 24px;border-radius:40px;font-size:1rem;font-weight:700;
  margin:14px auto 6px;border:2px solid;
}
.rb-ready{background:var(--green-light);color:var(--green);border-color:#a8d5bc}
.rb-developing{background:#fff8ec;color:var(--amber);border-color:#e8d080}
.rb-not-ready{background:var(--red-light);color:var(--red);border-color:#e5b8b2}
.results-sub{color:var(--ink-2);font-size:.88rem;text-align:center;margin-bottom:32px}

.res-card{background:var(--surface);border:1px solid var(--paper-3);border-radius:18px;padding:28px;margin-bottom:16px;box-shadow:var(--shadow)}

.ring-row{display:flex;align-items:center;gap:28px;margin-bottom:22px}
.ring-wrap{position:relative;width:96px;height:96px;flex-shrink:0}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-track{fill:none;stroke:var(--paper-3);stroke-width:8}
.ring-fill{fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1.1s cubic-bezier(.4,0,.2,1)}
.ring-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ring-pct{font-family:'DM Mono',monospace;font-size:1.3rem;font-weight:500;color:var(--ink)}
.ring-sub{font-size:.62rem;color:var(--ink-3);text-transform:uppercase;letter-spacing:.06em}
.ring-info-title{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:600;margin-bottom:5px}
.ring-info-sub{font-size:.82rem;color:var(--ink-2);line-height:1.65}

.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.stat-box{background:var(--paper);border-radius:10px;padding:14px;text-align:center}
.stat-val{font-family:'DM Mono',monospace;font-size:1.4rem;font-weight:500;color:var(--ink)}
.stat-lbl{font-size:.68rem;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-3);margin-top:2px}

/* Gap report */
.gap-section-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--ink-3);margin-bottom:12px}
.gap-row{
  display:flex;align-items:flex-start;gap:12px;padding:13px 0;
  border-bottom:1px solid var(--paper-3)
}
.gap-row:last-child{border-bottom:none}
.gap-icon{width:32px;height:32px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.9rem}
.gap-icon.miss{background:var(--red-light)}
.gap-icon.partial{background:#fff8ec}
.gap-icon.ok{background:var(--green-light)}
.gap-body{flex:1}
.gap-topic{font-size:.85rem;font-weight:600;color:var(--ink);margin-bottom:2px}
.gap-boost{font-size:.78rem;color:var(--ink-2);line-height:1.55}
.gap-boost strong{color:var(--navy);font-weight:600}

.res-actions{display:flex;gap:12px;margin-top:8px}
.res-btn{
  flex:1;padding:13px;border-radius:11px;font-family:'DM Sans',sans-serif;
  font-size:.88rem;font-weight:600;cursor:pointer;transition:all .15s;
  border:1.5px solid var(--paper-3);background:var(--surface);color:var(--ink-2);text-align:center
}
.res-btn:hover{border-color:var(--navy);color:var(--navy)}
.res-btn.primary{background:var(--navy);color:#fff;border-color:var(--navy)}
.res-btn.primary:hover{background:var(--navy-mid)}

/* ─── UTILS ─── */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--paper-3);border-radius:3px}

/* ─── MOBILE ─── */
.mob-nav-bar{
  display:none;background:var(--navy);height:48px;
  align-items:center;justify-content:space-between;
  padding:0 16px;flex-shrink:0;
}
.mob-nav-bar .topbar-logo{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:600;color:#fff}
.mob-nav-bar .topbar-logo em{font-style:italic;color:#f0c060}
.mob-menu-btn{
  background:rgba(255,255,255,.12);border:none;color:white;
  border-radius:7px;padding:6px 10px;font-size:.8rem;cursor:pointer;
}
.mob-q-drawer{
  display:none;position:fixed;inset:0;z-index:50;
  background:rgba(0,0,0,.5);
}
.mob-q-drawer.open{display:flex}
.mob-q-inner{
  width:280px;background:var(--surface);height:100%;
  overflow-y:auto;padding:16px;
}
.mob-q-close{
  display:flex;justify-content:flex-end;margin-bottom:12px;
}
.mob-q-close button{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--ink-2)}
.mob-progress-bar{
  height:3px;background:var(--paper-3);
}
.mob-progress-fill{height:100%;background:var(--navy);transition:width .3s}

@media(max-width:680px){
  /* Landing */
  .std-grid{grid-template-columns:1fr !important}
  .landing-logo{font-size:2.4rem}

  /* Exam shell */
  #s-exam{height:auto;min-height:100vh;overflow:visible}
  .exam-topbar{display:none}
  .mob-nav-bar{display:flex}
  .exam-body{flex-direction:column}
  .sidebar{display:none}
  .q-panel{padding:16px;overflow:visible}
  .q-card-body{padding:20px 18px}
  .q-title{font-size:1.15rem}
  .q-nav-row{padding:14px 18px;gap:8px}
  .btn-nav{padding:8px 12px;font-size:.78rem}
  .q-emoji{font-size:1.6rem}

  /* Results */
  #s-results{padding:32px 16px}
  .ring-row{flex-direction:column;align-items:flex-start;gap:16px}
  .res-card{padding:20px 16px}
}



#gate{position:fixed;top:0;left:0;width:100%;height:100%;background:#1a3fc4;z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px}
#gate.off{display:none!important}
.gc{background:white;border-radius:20px;padding:40px;max-width:400px;width:100%;text-align:center;font-family:'DM Sans',sans-serif}
.gl{font-family:'Fraunces',serif;font-size:2rem;font-weight:700;color:#1a3fc4;margin-bottom:6px}
.gl em{font-style:italic;color:#ff6b00}
.gi{width:100%;padding:14px;font-size:1.1rem;letter-spacing:.15em;text-transform:uppercase;border:2px solid #c8d8ff;border-radius:10px;text-align:center;margin-bottom:12px;font-family:monospace;outline:none;display:block}
.gi:focus{border-color:#1a3fc4}
.gb{width:100%;padding:14px;background:#ff6b00;color:white;border:none;border-radius:40px;font-size:1rem;font-weight:700;cursor:pointer;margin-bottom:16px;display:block}
.gb:hover{background:#e55a00}
.ge{color:#dc2626;font-size:.82rem;margin-bottom:12px;display:none;background:#fef2f2;padding:8px;border-radius:8px}
.glinks{font-size:.78rem;color:#6b7280}
.glinks a{color:#1a3fc4;font-weight:600;text-decoration:none}


/* ── CAN I PASS YET METER ── */
.pass-meter{
  background:linear-gradient(135deg,#0a1880,#1a3fc4);
  border-radius:20px;padding:24px 28px;margin-bottom:16px;
  text-align:center;color:white;
}
.pass-meter-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.55);margin-bottom:4px}
.pass-meter-title{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;margin-bottom:16px;color:white}
.cipy-ring-wrap{position:relative;width:120px;height:120px;margin:0 auto 12px}
.cipy-ring-wrap svg{transform:rotate(-90deg)}
.cipy-bg{fill:none;stroke:rgba(255,255,255,.15);stroke-width:10}
.cipy-fill{fill:none;stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset 1.2s cubic-bezier(.4,0,.2,1)}
.cipy-text{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.cipy-pct{font-family:'DM Mono',monospace;font-size:1.8rem;font-weight:500;color:white}
.cipy-sub{font-size:.6rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.07em}
.cipy-desc{font-size:.82rem;color:rgba(255,255,255,.7);line-height:1.65;max-width:360px;margin:0 auto}
.cipy-history{display:flex;justify-content:center;gap:8px;margin-top:12px;flex-wrap:wrap}
.cipy-session{font-size:.7rem;padding:3px 10px;border-radius:20px;background:rgba(255,255,255,.12);color:rgba(255,255,255,.6)}
</style>
</head>
<body>
<!-- GATE -->
<div id="gate">
  <div class="gc">
    <div class="gl">pass<em>it</em></div>
    <p style="font-size:.95rem;font-weight:700;color:#0a1440;margin-bottom:6px">CAA Full Access</p>
    <p style="font-size:.83rem;color:#6b7280;margin-bottom:22px">Enter your access code to unlock 60+ practice questions.</p>
    <input type="text" id="gi" class="gi" placeholder="ENTER CODE" maxlength="20">
    <div id="ge" class="ge">Incorrect code — please check your email from Passit.</div>
    <button class="gb" onclick="doUnlock()">Unlock Full Access →</button>
    <div class="glinks">No code? <a href="/">Get access at passit.co.nz</a> &nbsp;·&nbsp; <a href="/simulator.html">Try 6 free questions →</a></div>
  </div>
</div>



<!-- ══ LANDING ══════════════════════════════════════════════════ -->
<div id="s-landing" class="screen active">
  <div class="landing-badge">✦ Year 10 CAA Preparation</div>
  <div class="landing-logo">pass<em>it</em></div>
  <p class="landing-sub">Practice the co-requisite exams. See exactly where you stand.</p>

  <div class="std-grid">
    <div class="std-tile" data-s="32403" onclick="startExam('32403')">
      <div class="std-tile-bar"></div>
      <div class="std-tile-code">US 32403</div>
      <div class="std-tile-name">Reading</div>
      <div class="std-tile-credits">5 credits</div>
      <div class="std-tile-desc">Understand authentic NZ texts — workplace notices, timetables, product labels, safety instructions.</div>
      <button class="std-tile-cta">Start Practice →</button>
    </div>
    <div class="std-tile" data-s="32405" onclick="startExam('32405')">
      <div class="std-tile-bar"></div>
      <div class="std-tile-code">US 32405</div>
      <div class="std-tile-name">Writing</div>
      <div class="std-tile-credits">5 credits</div>
      <div class="std-tile-desc">Write clearly for purpose and audience — workplace emails, community notices, instructions, short reports.</div>
      <button class="std-tile-cta">Start Practice →</button>
    </div>
    <div class="std-tile" data-s="32406" onclick="startExam('32406')">
      <div class="std-tile-bar"></div>
      <div class="std-tile-code">US 32406</div>
      <div class="std-tile-name">Numeracy</div>
      <div class="std-tile-credits">10 credits</div>
      <div class="std-tile-desc">Apply number, measurement and statistics in real NZ contexts — shopping, budgets, data, rates, GST.</div>
      <button class="std-tile-cta">Start Practice →</button>
    </div>
  </div>

  <div class="landing-foot">
    <strong>About this simulator:</strong> Questions are built from published NZQA achievement criteria for US32403, US32405 and US32406.
    All contexts are New Zealand–specific. Actual CAA questions are not released by NZQA.
  </div>
</div>

<!-- ══ EXAM ══════════════════════════════════════════════════════ -->
<div id="s-exam" class="screen">

  <!-- Mobile top bar -->
  <div class="mob-nav-bar">
    <a href="index.html" style="color:rgba(255,255,255,.6);font-size:.75rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:4px;margin-right:10px">← Back</a><div class="topbar-logo">pass<em>it</em></div>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="timer-val" id="mob-timer-val" style="font-family:'DM Mono',monospace;font-size:.9rem;color:white">40:00</span>
      <button class="mob-menu-btn" onclick="document.getElementById('mob-drawer').classList.toggle('open')">☰ Questions</button>
    </div>
  </div>
  <div class="mob-progress-bar"><div class="mob-progress-fill" id="mob-progress-fill" style="width:0%"></div></div>

  <!-- Mobile question drawer -->
  <div class="mob-q-drawer" id="mob-drawer" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="mob-q-inner">
      <div class="mob-q-close"><button onclick="document.getElementById('mob-drawer').classList.remove('open')">✕</button></div>
      <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--ink-3);margin-bottom:12px" id="mob-section-label">Questions</div>
      <nav id="mob-q-list"></nav>
      <div class="ai-box" style="margin-top:16px">
        <div class="ai-box-head">✦ AI Hint</div>
        <div class="ai-box-text" id="mob-ai-hint">Choose a question for a hint.</div>
      </div>
    </div>
  </div>
  <header class="exam-topbar">
    <div class="topbar-left">
      <a href="index.html" style="color:rgba(255,255,255,.6);font-size:.75rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:4px;margin-right:10px">← Back</a><div class="topbar-logo">pass<em>it</em></div>
      <div class="topbar-std" id="topbar-std-label">CAA Numeracy — US32406</div>
    </div>
    <div class="topbar-right">
      <div class="timer-pill" id="timer-pill">
        <svg class="timer-icon" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="timer-val" id="timer-val">40:00</span>
      </div>
      <button class="submit-btn" onclick="submitExam()">Submit Exam</button>
    </div>
  </header>

  <div class="exam-body">
    <aside class="sidebar">
      <div class="sb-head">
        <span class="sb-head-label" id="sb-section">Questions</span>
        <span class="sb-progress" id="sb-progress">0/0</span>
      </div>
      <nav class="q-list" id="q-list"></nav>
      <div class="ai-box">
        <div class="ai-box-head">✦ AI Hint</div>
        <div class="ai-box-text" id="ai-hint">Choose a question to see a targeted hint.</div>
      </div>
    </aside>

    <main class="q-panel" id="q-panel"></main>
  </div>
</div>

<!-- ══ RESULTS ════════════════════════════════════════════════════ -->
<div id="s-results" class="screen">
  <div class="results-wrap">
    <div class="results-logo">pass<em>it</em></div>
    <div style="text-align:center">
      <div id="readiness-badge" class="readiness-badge rb-ready">✓ CAA-Ready</div>
    </div>
    <p class="results-sub" id="results-sub">You demonstrated the required skills for this standard.</p>

    
    <!-- CAN I PASS YET METER -->
    <div class="pass-meter" id="pass-meter" style="display:none">
      <div class="pass-meter-label">Can I pass yet?</div>
      <div class="pass-meter-title" id="cipy-title">CAA Readiness Score</div>
      <div class="cipy-ring-wrap">
        <svg viewBox="0 0 120 120" width="120" height="120">
          <circle class="cipy-bg" cx="60" cy="60" r="50"/>
          <circle class="cipy-fill" id="cipy-fill" cx="60" cy="60" r="50" stroke-dasharray="314" stroke-dashoffset="314"/>
        </svg>
        <div class="cipy-text">
          <div class="cipy-pct" id="cipy-pct">—</div>
          <div class="cipy-sub">ready</div>
        </div>
      </div>
      <p class="cipy-desc" id="cipy-desc"></p>
      <div class="cipy-history" id="cipy-history"></div>
    </div>
<div class="res-card">
      <div class="ring-row">
        <div class="ring-wrap">
          <svg viewBox="0 0 100 100" width="96" height="96">
            <circle class="ring-track" cx="50" cy="50" r="42"/>
            <circle class="ring-fill" id="ring-fill" cx="50" cy="50" r="42" stroke-dasharray="264" stroke-dashoffset="264"/>
          </svg>
          <div class="ring-label">
            <div class="ring-pct" id="ring-pct">—</div>
            <div class="ring-sub">score</div>
          </div>
        </div>
        <div>
          <div class="ring-info-title" id="res-std-name">CAA Numeracy</div>
          <div class="ring-info-sub" id="res-breakdown"></div>
        </div>
      </div>
      <div class="stat-row">
        <div class="stat-box"><div class="stat-val" id="st-correct">—</div><div class="stat-lbl">Correct</div></div>
        <div class="stat-box"><div class="stat-val" id="st-total">—</div><div class="stat-lbl">Questions</div></div>
        <div class="stat-box"><div class="stat-val" id="st-time">—</div><div class="stat-lbl">Time taken</div></div>
      </div>
    </div>

    <!-- Gap report -->
    <div class="res-card" id="gap-card">
      <div class="gap-section-title">Your Gap Report — Where to focus next</div>
      <div id="gap-list"></div>
      <div id="gap-locked" style="display:none;text-align:center;padding:20px;color:#6b7280;font-size:.85rem">
        <div style="font-size:1.5rem;margin-bottom:8px">🔒</div>
        Full Gap Report with Boost Tasks is included in full access.
      </div>
    </div>

    <div id="free-upgrade-banner" style="display:none;background:linear-gradient(135deg,#1a3fc4,#0a1880);border-radius:16px;padding:24px;margin-bottom:16px;text-align:center">
      <div style="font-family:Fraunces,serif;font-size:1.2rem;font-weight:700;color:white;margin-bottom:6px">You've completed the free preview!</div>
      <p style="font-size:.85rem;color:rgba(255,255,255,.75);margin-bottom:16px">Get full access to 22+ questions per standard, full exam mode, AI hints and your complete Gap Report.</p>
      <a href="index.html" style="display:inline-block;background:#ff6b00;color:white;padding:12px 28px;border-radius:40px;font-weight:700;font-size:.9rem;text-decoration:none">Get Full Access — $29.99 NZD →</a>
    </div>
    <div class="res-actions">
      <button class="res-btn" onclick="goHome()">← Try Another</button>
      <button class="res-btn primary" onclick="retryExam()">Retry This Standard</button>
    </div>
  </div>
</div>

<script>
// ══ QUESTION BANK ═════════════════════════════════════════════════════════

const BANK = {
  '32406': [
    { id:'n01',sec:'Shopping',emoji:'🍌',title:'Calculating at the Supermarket',
      scenario:'At Countdown, bananas cost <strong>$3.29 per kilogram</strong>.',
      callout:'You pick up a bunch that weighs <strong>685 grams</strong>.',
      type:'currency',task:'How much do you pay for the bananas? Round to the nearest cent.',
      answer:2.25,tol:.02,topic:'Unit conversion & multiplication',
      hint:'Convert grams to kilograms first (÷1000), then multiply by the price per kg.',
      explain:'685g ÷ 1000 = 0.685kg. 0.685 × $3.29 = $2.254 → <strong>$2.25</strong>',
      boost:'Practice: convert any weight in grams to kg, then multiply by a price per kg.' },
    { id:'n02',sec:'Shopping',emoji:'🧥',title:'Sale Price',
      scenario:'A jacket at Farmers costs <strong>$129.99</strong>.',callout:"It's on sale for <strong>30% off</strong>.",
      type:'currency',task:'What is the sale price?',
      answer:90.99,tol:.02,topic:'Percentages',
      hint:'Find 30% of $129.99 (multiply by 0.30), then subtract.',
      explain:'30% of $129.99 = $39.00. $129.99 − $39.00 = <strong>$90.99</strong>',
      boost:'Practise finding percentage discounts: multiply original by (1 − discount rate).' },
    { id:'n03',sec:'Budgeting',emoji:'💰',title:"Hemi's Weekly Budget",
      scenario:'Hemi earns <strong>$680/week</strong> after tax.',
      callout:'Expenses: rent $220, food $95, transport $45, phone $25.',
      type:'currency',task:'How much is left after all expenses?',
      answer:295,tol:0,topic:'Addition & subtraction',
      hint:'Add all expenses together, then subtract from $680.',
      explain:'Total expenses: $385. $680 − $385 = <strong>$295</strong>',
      boost:'Write out all expenses in a list and add them before subtracting — avoid skipping steps.' },
    { id:'n04',sec:'Measurement',emoji:'🏠',title:'Carpet Cost',
      scenario:'A bedroom is <strong>4.2 m long</strong> and <strong>3.5 m wide</strong>.',callout:'Carpet costs <strong>$28/m²</strong>.',
      type:'currency',task:'Total cost to carpet the room?',
      answer:411.6,tol:.05,topic:'Area & rates',
      hint:'Calculate area first (length × width), then multiply by cost per m².',
      explain:'Area = 4.2 × 3.5 = 14.7 m². 14.7 × $28 = <strong>$411.60</strong>',
      boost:'Remember: area of a rectangle = length × width. Always check your units.' },
    { id:'n05',sec:'Data',emoji:'📊',title:'Survey Results',
      scenario:'120 students chose a preferred sport.',callout:'Rugby 35%, Netball 25%, Football 20%, Basketball 12%, Other 8%.',
      type:'number',task:'How many students chose Rugby or Netball combined?',
      answer:72,tol:0,topic:'Percentages & whole numbers',
      hint:'Add the two percentages, then find that % of 120.',
      explain:'35% + 25% = 60%. 0.60 × 120 = <strong>72 students</strong>',
      boost:'To find a percentage of a number: convert % to a decimal (÷100), then multiply.' },
    { id:'n06',sec:'Time',emoji:'🚌',title:'Journey Planning',
      scenario:'Aroha must be at work by <strong>8:45 am</strong>.',callout:'Bus takes 35 min. She needs 15 min once she arrives.',
      type:'mc',task:'Latest time to leave home?',
      options:['7:45 am','7:55 am','8:00 am','7:50 am'],answer:'7:55 am',topic:'Time calculations',
      hint:'Work backwards from 8:45 am. Total time needed: 35 + 15 = 50 minutes.',
      explain:'8:45 am − 50 min = <strong>7:55 am</strong>',
      boost:'For time problems: identify the finish time and work backwards, adding each step.' },
    { id:'n07',sec:'Rates',emoji:'⛽',title:'Petrol for a Road Trip',
      scenario:"Petrol is <strong>$2.89/litre</strong>. Tama's car uses <strong>8.5L per 100km</strong>.",callout:'He drives 240 km.',
      type:'currency',task:"Total petrol cost? Round to the nearest cent.",
      answer:58.94,tol:.05,topic:'Rates & multi-step calculation',
      hint:'Step 1: find litres needed (8.5 × 240 ÷ 100). Step 2: multiply litres × price.',
      explain:'Litres: 8.5×240÷100 = 20.4L. Cost: 20.4 × $2.89 = <strong>$58.96</strong>',
      boost:'Multi-step rate problems: write out each step before calculating.' },
    { id:'n08',sec:'GST',emoji:'🔧',title:'Mechanic Invoice + GST',
      scenario:'Service charge: <strong>$340 + GST</strong>.',callout:'NZ GST is <strong>15%</strong>.',
      type:'currency',task:'Total amount payable including GST?',
      answer:391,tol:.01,topic:'GST & percentages',
      hint:'GST = $340 × 0.15. Add to the original amount.',
      explain:'$340 × 0.15 = $51. $340 + $51 = <strong>$391.00</strong>',
      boost:'Quick GST shortcut: multiply the pre-GST amount by 1.15.' },
    { id:'n09',sec:'Fractions',emoji:'🍕',title:'Splitting a Dinner Bill',
      scenario:'Five friends share a $143.50 bill.',callout:'They add a <strong>10% tip</strong> on top.',
      type:'currency',task:"Each person's share (including tip)?",
      answer:31.57,tol:.02,topic:'Multi-step: percentages & division',
      hint:'First find the total with tip (×1.10), then divide by 5.',
      explain:'$143.50 × 1.10 = $157.85. ÷5 = <strong>$31.57</strong>',
      boost:'Always complete all operations in order — adding the tip before dividing is critical.' },
    { id:'n10',sec:'Speed',emoji:'🚗',title:'Auckland to Hamilton',
      scenario:'Distance: <strong>128 km</strong>.',callout:'Average speed: <strong>96 km/h</strong>.',
      type:'mc',task:'Approximate travel time?',
      options:['1 hr 10 min','1 hr 20 min','1 hr 45 min','2 hrs'],answer:'1 hr 20 min',topic:'Speed, distance, time',
      hint:'Time = Distance ÷ Speed. Convert the decimal to minutes (×60).',
      explain:'128 ÷ 96 = 1.333… hrs = 1 hr 20 min',
      boost:'Speed formula triangle: Distance = Speed × Time. Cover what you want to find.' },
    { id:'n11',sec:'Shopping',emoji:'🛒',title:'Weekly Grocery Budget',
      scenario:'Mere has a weekly grocery budget of <strong>$120</strong>.',callout:'She has spent: $34.50 meat, $22.80 vegetables, $18.60 dairy, $15.90 pantry.',
      type:'currency',task:'How much of her budget does Mere have left?',
      answer:28.20,tol:.02,topic:'Multi-item subtraction',
      hint:'Add all spending first, then subtract from $120.',
      explain:'Total spent: $34.50+$22.80+$18.60+$15.90 = $91.80. $120.00 − $91.80 = <strong>$28.20</strong>',
      boost:'Write each item on a separate line and add carefully before subtracting.' },

    { id:'n12',sec:'Measurement',emoji:'📏',title:'Fencing a Section',
      scenario:'A rectangular section is <strong>24 m long</strong> and <strong>16 m wide</strong>.',callout:'Fencing costs <strong>$18.50 per metre</strong>.',
      type:'currency',task:'What is the total cost to fence the entire section?',
      answer:1480,tol:.50,topic:'Perimeter and rates',
      hint:'Step 1: Calculate perimeter (all four sides). Step 2: Multiply by cost per metre.',
      explain:'Perimeter = 2 × (24 + 16) = 80 m. Cost: 80 × $18.50 = <strong>$1,480.00</strong>',
      boost:'Perimeter of a rectangle = 2 × (length + width). Never multiply just one side by 4 unless it is a square.' },

    { id:'n13',sec:'Data',emoji:'📈',title:'Average Temperature',
      scenario:'MetService recorded Auckland temperatures last week:',callout:'Mon 18°, Tue 21°, Wed 19°, Thu 23°, Fri 20°, Sat 17°, Sun 22°',
      type:'number',task:'What was the average daily temperature? Round to one decimal place.',
      answer:20.0,tol:.1,topic:'Mean average',
      hint:'Add all 7 temperatures, then divide by 7.',
      explain:'Total: 18+21+19+23+20+17+22 = 140. 140 ÷ 7 = <strong>20.0°C</strong>',
      boost:'Mean = total ÷ number of values. Always count values before dividing.' },

    { id:'n14',sec:'Budgeting',emoji:'💳',title:'Hire Purchase vs Cash',
      scenario:'A TV costs <strong>$1,299 cash</strong>.',callout:'Hire purchase: <strong>$150 deposit</strong> + <strong>$89/month for 18 months</strong>.',
      type:'currency',task:'How much extra do you pay by choosing hire purchase?',
      answer:453,tol:.50,topic:'Comparing costs',
      hint:'Step 1: Total HP = deposit + (monthly × months). Step 2: Subtract cash price.',
      explain:'HP total: $150 + ($89 × 18) = $150 + $1,602 = $1,752. Extra: $1,752 − $1,299 = <strong>$453</strong>',
      boost:'Always calculate total HP cost first, then find the difference from cash price.' },

    { id:'n15',sec:'Rates',emoji:'🏃',title:'Charity Walk Time',
      scenario:"Hana walks at <strong>5.5 km/h</strong>.",callout:'The charity walkathon is <strong>22 km</strong> long.',
      type:'mc',task:'How long will it take Hana to complete the walk?',
      options:['3 hours','3 hours 30 minutes','4 hours','4 hours 30 minutes'],
      answer:'4 hours',topic:'Speed, distance, time',
      hint:'Time = Distance ÷ Speed. 22 ÷ 5.5 = ?',
      explain:'22 ÷ 5.5 = <strong>4 hours</strong> exactly.',
      boost:'If the division gives a whole number, that is your answer in hours — no minutes conversion needed.' },

    { id:'n16',sec:'GST',emoji:'🧾',title:'GST Refund for Tourist',
      scenario:'A tourist buys goods worth <strong>$340 including GST</strong>.',callout:'They are eligible for a GST refund. NZ GST is 15%.',
      type:'currency',task:'How much GST will they receive back?',
      answer:44.35,tol:.05,topic:'Extracting GST from GST-inclusive price',
      hint:'To find GST in a GST-inclusive price: price × 15 ÷ 115.',
      explain:'GST = $340 × 15 ÷ 115 = <strong>$44.35</strong>',
      boost:'Two types of GST: (1) adding GST = multiply by 1.15. (2) extracting GST = multiply by 15/115.' },

    { id:'n17',sec:'Data',emoji:'📊',title:'Favourite Subject Survey',
      scenario:'A school surveyed 240 students.',callout:'Results: Maths 35%, English 25%, Science 20%, PE 15%, Other 5%.',
      type:'number',task:'How many more students chose Maths than Science?',
      answer:36,tol:0,topic:'Percentage comparison',
      hint:'Find the number for Maths and Science separately, then subtract.',
      explain:'Maths: 35% × 240 = 84. Science: 20% × 240 = 48. Difference: 84 − 48 = <strong>36 students</strong>',
      boost:"For 'how many more' questions, always calculate both numbers separately before subtracting." },

    { id:'n18',sec:'Measurement',emoji:'🍰',title:'Baking Conversion',
      scenario:'A recipe needs <strong>750 ml of milk</strong>.',callout:'Tama only has a <strong>¼ cup measure</strong>. 1 cup = 250 ml.',
      type:'number',task:'How many quarter-cup measures does Tama need?',
      answer:12,tol:0,topic:'Unit conversion',
      hint:'Step 1: Convert 750 ml to cups (÷250). Step 2: Convert cups to quarter-cups (×4).',
      explain:'750 ÷ 250 = 3 cups. 3 × 4 = <strong>12 quarter-cup measures</strong>',
      boost:'Converting to a fraction of a unit means multiplying, not dividing.' },

    { id:'n19',sec:'Shopping',emoji:'📱',title:'Phone Plan Comparison',
      scenario:"Plan A: <strong>$35/month</strong>, 10GB, unlimited calls. Plan B: <strong>$25/month</strong>, 5GB, 200 min.",callout:"Pia uses 8GB data and 180 minutes monthly.",
      type:'mc',task:'Which plan suits Pia?',
      options:['Plan A — she needs more than 5GB data','Plan B — it is cheaper and she is under 200 min','Plan A — unlimited calls is always better','Either plan is suitable'],
      answer:'Plan A — she needs more than 5GB data',topic:'Multi-criteria decision making',
      hint:"Check if Pia fits Plan B — does she stay within BOTH the data AND the minutes limit?",
      explain:"Pia uses 8GB but Plan B only offers 5GB — she would exceed her data. Plan A is the only suitable option.",
      boost:"For plan comparisons: check whether the person FITS each plan before comparing price." },

    { id:'n20',sec:'Budgeting',emoji:'🏠',title:'Flat Expenses',
      scenario:'Four flatmates share costs: rent <strong>$2,400</strong>, power <strong>$180</strong>, internet <strong>$80</strong>, water <strong>$60</strong>.',callout:'Costs split equally.',
      type:'currency',task:'What does each flatmate pay per month?',
      answer:680,tol:.01,topic:'Addition and division',
      hint:'Add all costs first, then divide by 4.',
      explain:'Total: $2,400+$180+$80+$60 = $2,720. Per person: $2,720 ÷ 4 = <strong>$680</strong>',
      boost:'Always add all costs before dividing — it is faster and less error-prone.' },

    { id:'n21',sec:'Rates',emoji:'🌿',title:'Lawn Mowing Cost',
      scenario:"A lawn mowing service charges <strong>$0.08 per m²</strong>.",callout:"Wiremu's lawn is 18 m × 12 m.",
      type:'currency',task:"What is the cost to mow Wiremu's lawn?",
      answer:17.28,tol:.02,topic:'Area and rates',
      hint:'Step 1: Area = length × width. Step 2: Cost = area × rate.',
      explain:'Area: 18 × 12 = 216 m². Cost: 216 × $0.08 = <strong>$17.28</strong>',
      boost:'Area problems: find area first, then apply the rate. Write: Cost = Area × Rate.' },

    { id:'n22',sec:'Fractions',emoji:'🎂',title:'Unequal Prize Share',
      scenario:'A team of 5 wins <strong>$875</strong>.',callout:'Two members each get a double share; the other three get a single share.',
      type:'currency',task:'How much does each single-share member receive?',
      answer:125,tol:.01,topic:'Ratio and division',
      hint:'Count total shares: 2+2+1+1+1 = 7. Find one share value by dividing total by 7.',
      explain:'7 shares total. One share: $875 ÷ 7 = $125. Single-share members receive <strong>$125</strong>.',
      boost:'Unequal sharing: convert everything to single shares first, then divide the total.' },

  ],
  '32403': [
    { id:'r01',sec:'Workplace',emoji:'📋',title:'Fire Drill Notice',
      passageTitle:'STAFF NOTICE — Fire Evacuation Drill',
      passage:`All staff must complete a fire evacuation drill on Thursday 15 August at 2:00 pm. When the alarm sounds, stop all work immediately and exit via the nearest fire door. Do not use lifts. Assemble at the car park on Trent Street.\n\nStaff working from home that day must notify their manager before 9 am. Fire warden: Sarah Kim (ext. 204).`,
      type:'mc',task:'Where should staff assemble during the drill?',
      options:['Main entrance','Car park on Trent Street','Fire exit Level 2','Outside staff room'],
      answer:'Car park on Trent Street',topic:'Locating specific information',
      hint:"Find the word 'Assemble' in the notice.",
      explain:"The notice states: 'Assemble at the car park on Trent Street.'",
      boost:"When locating information: scan for a key word from the question (here: 'assemble')." },
    { id:'r02',sec:'Workplace',emoji:'📋',title:'Working from Home Rule',
      passageTitle:'STAFF NOTICE — Fire Evacuation Drill',
      passage:`All staff must complete a fire evacuation drill on Thursday 15 August at 2:00 pm. When the alarm sounds, stop all work immediately and exit via the nearest fire door. Do not use lifts. Assemble at the car park on Trent Street.\n\nStaff working from home that day must notify their manager before 9 am. Fire warden: Sarah Kim (ext. 204).`,
      type:'mc',task:'What must work-from-home staff do on that day?',
      options:['Come in for the drill','Notify manager before 9 am','Call ext. 204','Complete drill online'],
      answer:'Notify manager before 9 am',topic:'Locating specific information',
      hint:"Find the sentence that mentions 'working from home'.",
      explain:"The notice states: 'Staff working from home that day must notify their manager before 9 am.'",
      boost:'Read each option carefully — some are plausible but appear nowhere in the text.' },
    { id:'r03',sec:'Timetables',emoji:'🚌',title:'Catching the Right Bus',
      passageTitle:'Metro Bus — Route 22 Weekday Timetable',
      passage:`Central Station:   6:15  7:00  7:45  8:30  9:15\nKings Ave:         6:22  7:07  7:52  8:37  9:22\nRainbow Road:      6:31  7:16  8:01  8:46  9:31\nAirport Terminal:  6:48  7:33  8:18  9:03  9:48\n\nNote: Buses do not run on public holidays. Journey time approx. 33 minutes.`,
      type:'mc',task:'Latest bus from Central to arrive at Airport Terminal before 8:20 am?',
      options:['6:15 bus','7:00 bus','7:45 bus','8:30 bus'],answer:'7:45 bus',topic:'Reading timetables',
      hint:"Find all arrival times at Airport Terminal before 8:20 am, then pick the latest departure.",
      explain:'7:45 bus arrives 8:18 am (before 8:20). 8:30 bus arrives 9:03 am (too late).',
      boost:'For timetable questions: find the arrival column first, then trace back to the departure.' },
    { id:'r04',sec:'Product Labels',emoji:'🧺',title:'Laundry Powder Directions',
      passageTitle:'Laundry Powder — Directions for Use',
      passage:`Front loader: Use 60 ml per load. For heavily soiled items, increase to 80 ml.\nTop loader: Use 100 ml per load.\nHandwashing: Dissolve 15 ml in warm water before adding clothes.\n\n⚠ CAUTION: Keep out of reach of children. Do not mix with bleach. If swallowed, seek medical advice immediately.\nStorage: Store in a cool, dry place away from direct sunlight.`,
      type:'mc',task:'Amount for heavily soiled items in a front loader?',
      options:['60 ml','80 ml','100 ml','15 ml'],answer:'80 ml',topic:'Following instructions',
      hint:"Find 'Front loader' and look for 'heavily soiled'.",
      explain:"The label states: 'For heavily soiled items, increase to 80 ml.'",
      boost:"'Increase to' means use that amount — not 60 ml + 80 ml." },
    { id:'r05',sec:'Forms',emoji:'📚',title:'Library Membership',
      passageTitle:'Selwyn Library — New Member Application',
      passage:`Membership is free for all Selwyn District residents. To join:\n• Proof of current address (utility bill, bank statement, or letter dated within 3 months)\n• Photo ID (driver's licence, passport, or 18+ card)\n• Complete this form and return to the front desk\n\nMembers may borrow up to 8 items. Items kept for 3 weeks; renewed twice online. Overdue fines: 20c per item per day.`,
      type:'mc',task:'How many times can a borrowed item be renewed?',
      options:['Once','Twice','Three times','Cannot be renewed'],answer:'Twice',topic:'Locating specific information',
      hint:"Search for the word 'renewed' in the text.",
      explain:"The form states: 'Items may be kept for 3 weeks and renewed twice online.'",
      boost:'Underline or highlight key facts when reading — especially numbers and limits.' },
    { id:'r06',sec:'Health & Safety',emoji:'⚠️',title:'Chemical Safety Notice',
      passageTitle:'Cleaning Fluid X4 — Safety Data Sheet',
      passage:`HAZARD: Irritant. Avoid contact with skin and eyes.\n\nFIRST AID:\n• Skin contact: Rinse with water for at least 15 minutes.\n• Eye contact: Flush with water for 20 minutes. Seek medical attention immediately.\n• If swallowed: Do NOT induce vomiting. Call Poison Control: 0800 764 766.\n\nSTORAGE: Keep container sealed in a ventilated area. Do not store near food.\nPPE: Chemical-resistant gloves and safety glasses required.`,
      type:'mc',task:'If the fluid gets in someone\'s eyes, what should be done FIRST?',
      options:['Call Poison Control','Flush with water for 20 minutes','Rinse with water for 15 minutes','Seek medical attention'],
      answer:'Flush with water for 20 minutes',topic:'Sequencing / following instructions',
      hint:"Find 'Eye contact' and read the first step listed.",
      explain:"Eye contact: 'Flush with water for 20 minutes' — this comes before seeking medical attention.",
      boost:"Safety data sheets list steps in order. The first bullet point is always the first action." },

    // ── Inference / purpose questions ──
    { id:'r07',sec:'Workplace',emoji:'📋',title:'Purpose of the Notice',
      passageTitle:'STAFF NOTICE — Fire Evacuation Drill',
      passage:`All staff must complete a fire evacuation drill on Thursday 15 August at 2:00 pm. When the alarm sounds, stop all work immediately and exit via the nearest fire door. Do not use lifts. Assemble at the car park on Trent Street.\n\nStaff working from home that day must notify their manager before 9 am. Fire warden: Sarah Kim (ext. 204).`,
      type:'mc',task:"What is the main purpose of this notice?",
      options:['To introduce Sarah Kim to staff','To warn staff about a real fire risk','To tell staff what to do during a practice evacuation','To explain the building\'s fire door locations'],
      answer:"To tell staff what to do during a practice evacuation",topic:"Writer's purpose",
      hint:"Ask yourself: why was this written? What does the writer want readers to DO?",
      explain:"The notice gives instructions for a drill — a practice, not a real emergency. Its purpose is to prepare staff for the evacuation procedure.",
      boost:"Purpose questions: ask what action the writer wants readers to take, or what problem the text solves." },

    { id:'r08',sec:'Workplace',emoji:'📋',title:'What Happens if You Ignore the Notice',
      passageTitle:'STAFF NOTICE — Fire Evacuation Drill',
      passage:`All staff must complete a fire evacuation drill on Thursday 15 August at 2:00 pm. When the alarm sounds, stop all work immediately and exit via the nearest fire door. Do not use lifts. Assemble at the car park on Trent Street.\n\nStaff working from home that day must notify their manager before 9 am. Fire warden: Sarah Kim (ext. 204).`,
      type:'mc',task:"If a work-from-home staff member does NOT notify their manager before 9 am, what is most likely to happen?",
      options:['They will be fined','Their manager will not know they are absent from the drill','They will need to come into work','They will contact Sarah Kim instead'],
      answer:"Their manager will not know they are absent from the drill",topic:'Inference — implied consequence',
      hint:"The notice doesn't state a penalty — think about WHY the notification is needed. What problem does it solve for the manager?",
      explain:"The notification requirement exists so managers can account for all staff during the drill. Without it, a manager would not know whether a work-from-home employee had participated.",
      boost:"Inference questions: the answer isn't stated directly. Use what you know about the situation to work out what would logically follow." },

    { id:'r09',sec:'Product Labels',emoji:'🧺',title:'Why the Warning is in the Label',
      passageTitle:'Laundry Powder — Directions for Use',
      passage:`Front loader: Use 60 ml per load. For heavily soiled items, increase to 80 ml.\nTop loader: Use 100 ml per load.\nHandwashing: Dissolve 15 ml in warm water before adding clothes.\n\n⚠ CAUTION: Keep out of reach of children. Do not mix with bleach. If swallowed, seek medical advice immediately.\nStorage: Store in a cool, dry place away from direct sunlight.`,
      type:'mc',task:"Why has the manufacturer included the CAUTION section on this label?",
      options:['To explain how the product works','To warn users about potential safety risks','To meet government export requirements','To describe how to store the product'],
      answer:'To warn users about potential safety risks',topic:"Writer's purpose — safety texts",
      hint:"Look at what the CAUTION section actually contains — what kind of information is it giving readers?",
      explain:"The CAUTION section lists risks (harmful to children, dangerous with bleach, toxic if swallowed) — its clear purpose is to warn users about safety hazards.",
      boost:"Purpose questions on labels: manufacturers include caution sections to protect users from harm and meet safety obligations." },

    { id:'r10',sec:'Timetables',emoji:'🚌',title:'Planning for Delays',
      passageTitle:'Metro Bus — Route 22 Weekday Timetable',
      passage:`Central Station:   6:15  7:00  7:45  8:30  9:15\nKings Ave:         6:22  7:07  7:52  8:37  9:22\nRainbow Road:      6:31  7:16  8:01  8:46  9:31\nAirport Terminal:  6:48  7:33  8:18  9:03  9:48\n\nNote: Buses do not run on public holidays. Journey time approx. 33 minutes.`,
      type:'mc',task:"A passenger missed the 7:45 bus from Central Station. Their flight departs at 9:30 am and they need to be at the terminal 45 minutes before departure. Can they make it on the next bus?",
      options:['Yes — the 8:30 bus arrives with 12 minutes to spare','No — the 8:30 bus arrives too late','Yes — the 8:30 bus arrives exactly on time','There is not enough information to decide'],
      answer:'No — the 8:30 bus arrives too late',topic:'Multi-step inference from a timetable',
      hint:"Work out when the passenger must arrive at the terminal (9:30 − 45 min). Then check what time the 8:30 bus arrives.",
      explain:"Must arrive by 8:45 am (9:30 − 45 min). The 8:30 bus from Central arrives at Airport Terminal at 9:03 am — that's 18 minutes too late.",
      boost:"Multi-step timetable questions: write down the deadline first (departure − buffer), then check if the bus arrives before it." },
    { id:'r11',sec:'Workplace',emoji:'📧',title:'Staff Meeting Email',
      passageTitle:'Email — Upcoming Staff Meeting',
      passage:`From: James Taufa, Operations Manager\nTo: All Staff\nSubject: Mandatory Staff Meeting — Thursday 10 April\n\nPlease note there will be a mandatory all-staff meeting this Thursday 10 April at 3:30 pm in the Main Conference Room (Level 2).\n\nAgenda items include: Q1 performance review, new Health & Safety protocols, and parking changes effective 1 May.\n\nLight refreshments will be provided. Please confirm your attendance by replying to this email before 5 pm Wednesday.\nStaff unable to attend must notify their team leader and will receive meeting notes by Friday.`,
      type:'mc',task:'What must staff who cannot attend the meeting do?',
      options:['Email James Taufa directly','Reply to the email before Wednesday 5 pm','Notify their team leader','Collect meeting notes from Level 2'],
      answer:'Notify their team leader',topic:'Locating specific information',
      hint:"Find the sentence that mentions staff who cannot attend.",
      explain:"The email states staff unable to attend must notify their team leader.",
      boost:"Always read the full text — the answer to 'what must they do' is often in the final sentence." },

    { id:'r12',sec:'Workplace',emoji:'📧',title:'Meeting Deadline',
      passageTitle:'Email — Upcoming Staff Meeting',
      passage:`From: James Taufa, Operations Manager\nTo: All Staff\nSubject: Mandatory Staff Meeting — Thursday 10 April\n\nPlease note there will be a mandatory all-staff meeting this Thursday 10 April at 3:30 pm in the Main Conference Room (Level 2).\n\nAgenda items include: Q1 performance review, new Health & Safety protocols, and parking changes effective 1 May.\n\nLight refreshments will be provided. Please confirm your attendance by replying to this email before 5 pm Wednesday.\nStaff unable to attend must notify their team leader and will receive meeting notes by Friday.`,
      type:'mc',task:'By when must staff confirm their attendance?',
      options:['Thursday 10 April at 3:30 pm','Wednesday at 5 pm','Friday morning','Before the end of the week'],
      answer:'Wednesday at 5 pm',topic:'Locating specific information',
      hint:"Look for the word 'confirm' in the email.",
      explain:"The email states: 'Please confirm your attendance by replying to this email before 5 pm Wednesday.'",
      boost:"Time and deadline questions: scan for words like 'by', 'before', 'deadline', 'due'." },

    { id:'r13',sec:'Health & Safety',emoji:'🧤',title:'PPE Requirements',
      passageTitle:'Site Safety Notice — Personal Protective Equipment',
      passage:`All workers entering the construction zone MUST wear the following PPE at all times:\n\n• Hard hat (must meet AS/NZS 1801 standard)\n• Hi-visibility vest (orange or yellow)\n• Steel-capped boots\n• Safety glasses when operating machinery\n\nVisitors must sign in at the site office and will be issued a visitor hard hat and vest. No visitor may enter without a site induction.\n\nPPE not meeting standards will be confiscated. Workers without correct PPE will be stood down until compliant.`,
      type:'mc',task:'When are safety glasses required?',
      options:['At all times on site','Only for visitors','When operating machinery','When wearing a hard hat'],
      answer:'When operating machinery',topic:'Following instructions — conditions',
      hint:"Find 'safety glasses' in the text and read the condition next to it.",
      explain:"The notice states safety glasses are required 'when operating machinery' — not at all times.",
      boost:"Conditional requirements have trigger words like 'when', 'if', 'only when' — find these first." },

    { id:'r14',sec:'Health & Safety',emoji:'🧤',title:'PPE Non-Compliance',
      passageTitle:'Site Safety Notice — Personal Protective Equipment',
      passage:`All workers entering the construction zone MUST wear the following PPE at all times:\n\n• Hard hat (must meet AS/NZS 1801 standard)\n• Hi-visibility vest (orange or yellow)\n• Steel-capped boots\n• Safety glasses when operating machinery\n\nVisitors must sign in at the site office and will be issued a visitor hard hat and vest. No visitor may enter without a site induction.\n\nPPE not meeting standards will be confiscated. Workers without correct PPE will be stood down until compliant.`,
      type:'mc',task:'What happens to a worker whose PPE does not meet standards?',
      options:['They must buy new PPE immediately','Their PPE is confiscated and they are stood down','They receive a written warning','They must leave the site permanently'],
      answer:'Their PPE is confiscated and they are stood down',topic:'Locating specific information',
      hint:"Find the sentence about PPE 'not meeting standards'.",
      explain:"The notice states: 'PPE not meeting standards will be confiscated. Workers without correct PPE will be stood down until compliant.'",
      boost:"Two-part consequences are common in safety notices — read the full sentence, not just the first clause." },

    { id:'r15',sec:'Forms',emoji:'📋',title:'Rental Application',
      passageTitle:'Tenancy Application — Required Documents',
      passage:`To apply for this property, all applicants aged 18 and over must provide:\n\n1. Completed application form (one per adult applicant)\n2. Photo ID — driver's licence or passport\n3. Proof of income — last two payslips or a letter from your employer\n4. Three references — at least one must be a previous landlord\n5. Bond equivalent to four weeks' rent\n\nApplications without all required documents will not be processed. The bond is held by Tenancy Services and is refundable at end of tenancy (subject to property condition).\n\nProcessing time: 3–5 working days.`,
      type:'mc',task:'How many references are required, and what is the minimum requirement?',
      options:['Two references, one from an employer','Three references, one must be a previous landlord','Three references, all from previous landlords','Two references, one must be a family member'],
      answer:'Three references, one must be a previous landlord',topic:'Multi-part information retrieval',
      hint:"Find the references point — it has two pieces of information.",
      explain:"Point 4 states: 'Three references — at least one must be a previous landlord.'",
      boost:"Multi-part questions: find the main number first, then look for the condition attached to it." },

    { id:'r16',sec:'Forms',emoji:'📋',title:'Bond Holder',
      passageTitle:'Tenancy Application — Required Documents',
      passage:`To apply for this property, all applicants aged 18 and over must provide:\n\n1. Completed application form (one per adult applicant)\n2. Photo ID — driver's licence or passport\n3. Proof of income — last two payslips or a letter from your employer\n4. Three references — at least one must be a previous landlord\n5. Bond equivalent to four weeks' rent\n\nApplications without all required documents will not be processed. The bond is held by Tenancy Services and is refundable at end of tenancy (subject to property condition).\n\nProcessing time: 3–5 working days.`,
      type:'mc',task:'Who holds the bond money during the tenancy?',
      options:['The landlord','The property manager','Tenancy Services','The applicant'],
      answer:'Tenancy Services',topic:'Locating specific information',
      hint:"Find the word 'bond' after the numbered list.",
      explain:"The form states: 'The bond is held by Tenancy Services.'",
      boost:"Information about processes is often in the paragraph after the main list — always read past the bullet points." },

    { id:'r17',sec:'Timetables',emoji:'🚂',title:'First Available Train',
      passageTitle:'Northbound Train Schedule',
      passage:`Picton dep:       06:20  09:15  12:45  16:30  19:00\nBlenheim arr:     06:58  09:53  13:23  17:08  19:38\nKaikoura arr:     08:42  11:37  15:07  18:52  21:22\nChristchurch arr: 11:15  14:10  17:40  21:25  23:55\n\nNote: Bookings essential. Luggage limit 2 bags. Cafe car on all services except 19:00.`,
      type:'mc',task:'A passenger arrives at Picton at 9 am. Which is the first train they can catch to Christchurch?',
      options:['06:20 from Picton','09:15 from Picton','12:45 from Picton','16:30 from Picton'],
      answer:'09:15 from Picton',topic:'Reading timetables — practical application',
      hint:"The passenger arrives at 9 am. Find the first departure AFTER 9 am.",
      explain:"The 06:20 has already left. The 09:15 is the first departure after 9 am.",
      boost:"For 'first available' questions: cross out all departures before your arrival time, then pick the earliest remaining." },

    { id:'r18',sec:'Timetables',emoji:'🚂',title:'Cafe Car Availability',
      passageTitle:'Northbound Train Schedule',
      passage:`Picton dep:       06:20  09:15  12:45  16:30  19:00\nBlenheim arr:     06:58  09:53  13:23  17:08  19:38\nKaikoura arr:     08:42  11:37  15:07  18:52  21:22\nChristchurch arr: 11:15  14:10  17:40  21:25  23:55\n\nNote: Bookings essential. Luggage limit 2 bags. Cafe car on all services except 19:00.`,
      type:'mc',task:'A passenger on the 19:00 service wants to buy food on board. Is this possible?',
      options:['Yes — all trains have a cafe car','No — the 19:00 has no cafe car','Yes — but hot food only','Not enough information'],
      answer:'No — the 19:00 has no cafe car',topic:'Reading notes and exceptions',
      hint:"Check the Note at the bottom — it mentions an exception for one service.",
      explain:"The note states the cafe car is available on all services 'except 19:00 departure'.",
      boost:"Always read the notes in a timetable — exceptions are always listed there, not in the main table." },

    { id:'r19',sec:'Health & Safety',emoji:'🔋',title:'Battery Charger Warning Signs',
      passageTitle:'Lithium Battery Charger — Safety Instructions',
      passage:`READ ALL INSTRUCTIONS BEFORE USE.\n\nSAFE USE:\n• Only use with compatible lithium batteries\n• Charge in a well-ventilated area away from flammable materials\n• Do not charge unattended or overnight\n• Unplug when charging is complete\n\nWARNING SIGNS — Stop charging immediately if you notice:\n• Unusual heat, smell, or smoke\n• Battery swelling or leaking\n• Sparking or crackling sounds\n\nSTORAGE: Store in a cool, dry place. Do not store in a vehicle in direct sunlight.`,
      type:'mc',task:'According to the instructions, when should you stop charging immediately?',
      options:['After 4 hours of charging','When the battery feels warm','If you notice unusual heat, smell, smoke, swelling, leaking, sparking or crackling','Only if there is visible smoke or fire'],
      answer:'If you notice unusual heat, smell, smoke, swelling, leaking, sparking or crackling',topic:'Following safety instructions — completeness',
      hint:"Find the WARNING SIGNS section — list ALL conditions mentioned.",
      explain:"The Warning Signs section lists all trigger conditions: heat, smell, smoke, swelling, leaking, sparking, or crackling.",
      boost:"Safety questions often require you to list ALL conditions — partial answers are wrong. Include everything mentioned." },

    { id:'r20',sec:'Workplace',emoji:'🏥',title:'Leave Policy',
      passageTitle:'Annual Leave Policy — HR Guidelines',
      passage:`Annual leave must be applied for at least 2 weeks in advance via the HR portal. Leave during peak periods (20 December – 10 January and Easter weekend) requires 6 weeks notice and manager approval.\n\nEntitlement: Full-time staff accrue 4 weeks leave per year. Part-time staff accrue leave on a pro-rata basis.\n\nLeave without pay may be approved for personal circumstances at the manager's discretion. Staff must have exhausted all annual leave before applying for leave without pay.\n\nSick leave requires a medical certificate for absences of 3 or more consecutive days.`,
      type:'mc',task:'A staff member wants leave from 22 December to 5 January. How much notice is required?',
      options:['2 weeks','4 weeks','6 weeks','No notice required during the holidays'],
      answer:'6 weeks',topic:'Applying policy conditions',
      hint:"Check whether 22 December to 5 January falls within the peak period, then apply the correct rule.",
      explain:"22 December to 5 January falls within the peak period (20 Dec – 10 Jan), requiring 6 weeks notice.",
      boost:"Policy questions often have a general rule AND an exception — always check if your scenario triggers the exception." },

    { id:'r21',sec:'Community',emoji:'🏊',title:'Swim School Class',
      passageTitle:'AquaKids Swim School — Class Information',
      passage:`Classes available for ages 6 months to 16 years. All lessons 30 minutes.\n\nLevels:\n• Tadpoles (6 months–3 years): parent must enter water\n• Frogs (3–5 years): teacher-led, no parent in water\n• Dolphins (6–12 years): independent swimming\n• Sharks (13–16 years): stroke technique and fitness\n\nPayment: Full term fees (10 weeks) due at enrolment. No refunds for missed classes — catch-up lessons available on request.\n\nPlease disclose any medical conditions at enrolment.`,
      type:'mc',task:'A parent brings their 4-year-old to enrol. Which class is correct, and does the parent enter the water?',
      options:['Tadpoles — parent must enter the water','Frogs — parent does not enter the water','Dolphins — the child swims independently','Frogs — parent must enter the water'],
      answer:'Frogs — parent does not enter the water',topic:'Applying information to a scenario',
      hint:"Find the age group for a 4-year-old, then check the parent requirement for that class.",
      explain:"A 4-year-old is in Frogs (3–5 years). The Frogs class is teacher-led — no parent in the water.",
