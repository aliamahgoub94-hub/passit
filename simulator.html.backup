<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Passit — CAA Practice Simulator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #12100e;
  --ink-2: #4a4540;
  --ink-3: #9a928a;
  --paper: #f7f4f0;
  --paper-2: #efecea;
  --paper-3: #e5e0d8;
  --surface: #ffffff;
  --navy: #1c3557;
  --navy-mid: #2d5080;
  --navy-light: #eef2f8;
  --gold: #c08a28;
  --gold-light: #fdf5e4;
  --green: #1a6040;
  --green-light: #ebf5ef;
  --red: #aa3428;
  --red-light: #fdf0ee;
  --amber: #c47a18;
  --r: 14px;
  --shadow: 0 2px 12px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.04);
  --shadow-lg: 0 8px 32px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.05);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased}

/* ─── SCREENS ─── */
.screen{display:none}
.screen.active{display:flex}

/* ─── LANDING ─── */
#s-landing{
  min-height:100vh;flex-direction:column;align-items:center;justify-content:center;
  padding:48px 20px;background:var(--paper);
  background-image:radial-gradient(circle at 70% 20%, rgba(28,53,87,.05) 0%, transparent 55%),
                   radial-gradient(circle at 20% 80%, rgba(192,138,40,.06) 0%, transparent 50%);
}
.landing-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--navy-light);color:var(--navy);
  font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:5px 14px;border-radius:40px;border:1px solid #c8d8ee;
  margin-bottom:28px;
}
.landing-logo{
  font-family:'Fraunces',serif;font-size:3.2rem;font-weight:700;
  color:var(--navy);letter-spacing:-2px;line-height:1;margin-bottom:8px;
}
.landing-logo em{font-style:italic;color:var(--gold)}
.landing-sub{color:var(--ink-2);font-size:1.05rem;font-weight:300;margin-bottom:56px;text-align:center}

.std-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;max-width:860px;width:100%;margin-bottom:40px}
@media(max-width:700px){.std-grid{grid-template-columns:1fr}}

.std-tile{
  background:var(--surface);border:1.5px solid var(--paper-3);
  border-radius:var(--r);padding:24px 22px;cursor:pointer;
  transition:all .2s ease;position:relative;overflow:hidden;
}
.std-tile:hover{border-color:var(--navy-mid);box-shadow:var(--shadow-lg);transform:translateY(-3px)}
.std-tile-bar{position:absolute;top:0;left:0;right:0;height:3px}
.std-tile[data-s="32403"] .std-tile-bar{background:#3d80cc}
.std-tile[data-s="32405"] .std-tile-bar{background:var(--green)}
.std-tile[data-s="32406"] .std-tile-bar{background:var(--gold)}

.std-tile-code{font-family:'DM Mono',monospace;font-size:.68rem;color:var(--ink-3);letter-spacing:.06em;margin-bottom:10px}
.std-tile-name{font-family:'Fraunces',serif;font-size:1.4rem;font-weight:600;margin-bottom:6px}
.std-tile-credits{
  display:inline-flex;align-items:center;gap:4px;
  background:var(--navy-light);color:var(--navy);
  font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:14px
}
.std-tile-desc{font-size:.83rem;color:var(--ink-2);line-height:1.65;margin-bottom:20px}
.std-tile-cta{
  width:100%;padding:10px;background:var(--navy);color:#fff;
  border:none;border-radius:9px;font-family:'DM Sans',sans-serif;
  font-size:.83rem;font-weight:600;cursor:pointer;transition:background .15s
}
.std-tile-cta:hover{background:var(--navy-mid)}

.landing-foot{
  max-width:580px;text-align:center;font-size:.78rem;color:var(--ink-3);
  line-height:1.8;padding:14px 20px;border:1px solid var(--paper-3);
  border-radius:var(--r);background:var(--surface)
}

/* ─── EXAM SHELL ─── */
#s-exam{flex-direction:column;height:100vh;overflow:hidden}

.exam-topbar{
  height:54px;background:var(--navy);display:flex;align-items:center;
  justify-content:space-between;padding:0 20px;flex-shrink:0;z-index:20
}
.topbar-left{display:flex;align-items:center;gap:14px}
.topbar-logo{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:600;color:#fff;letter-spacing:-.5px}
.topbar-logo em{font-style:italic;color:#f0c060}
.topbar-std{font-size:.75rem;color:rgba(255,255,255,.5);padding-left:14px;border-left:1px solid rgba(255,255,255,.15)}
.topbar-right{display:flex;align-items:center;gap:14px}

.timer-pill{
  display:flex;align-items:center;gap:7px;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);
  border-radius:8px;padding:5px 13px;
}
.timer-icon{width:13px;height:13px;opacity:.6}
.timer-val{font-family:'DM Mono',monospace;font-size:.95rem;font-weight:500;color:#fff;letter-spacing:.04em}
.timer-pill.warn .timer-val{color:#ffc947}
.timer-pill.danger .timer-val{color:#ff7070}

.submit-btn{
  background:#22c55e;color:#fff;border:none;border-radius:8px;
  padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.8rem;
  font-weight:700;cursor:pointer;transition:background .15s
}
.submit-btn:hover{background:#16a34a}

.exam-body{display:flex;flex:1;overflow:hidden}

/* ─── SIDEBAR ─── */
.sidebar{
  width:252px;flex-shrink:0;background:var(--surface);
  border-right:1px solid var(--paper-3);display:flex;flex-direction:column;overflow:hidden
}
.sb-head{
  padding:12px 14px;border-bottom:1px solid var(--paper-3);
  display:flex;justify-content:space-between;align-items:center
}
.sb-head-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--ink-3)}
.sb-progress{font-size:.7rem;font-weight:700;color:var(--navy);background:var(--navy-light);padding:2px 8px;border-radius:20px}

.q-list{flex:1;overflow-y:auto;padding:6px}
.q-item{
  display:flex;align-items:center;gap:8px;padding:9px 10px;
  border-radius:9px;cursor:pointer;transition:all .12s;margin-bottom:2px;
  border-left:2px solid transparent;
}
.q-item:hover{background:var(--paper)}
.q-item.is-active{background:var(--navy-light);border-left-color:var(--navy)}
.q-item.is-answered{background:var(--green-light)}
.q-item.is-active.is-answered{background:var(--navy-light)}
.q-item.is-flagged{background:#fff8ec;border-left-color:var(--gold)}

.q-item-num{
  width:22px;height:22px;border-radius:50%;border:1.5px solid var(--paper-3);
  flex-shrink:0;display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:700;color:var(--ink-3);transition:all .12s
}
.q-item.is-active .q-item-num{border-color:var(--navy);background:var(--navy);color:#fff}
.q-item.is-answered .q-item-num{border-color:var(--green);background:var(--green);color:#fff}
.q-item.is-answered .q-item-num::after{content:'✓'}
.q-item.is-answered:not(.is-active) .q-item-num{font-size:0}
.q-item.is-flagged .q-item-num{border-color:var(--gold);background:var(--gold-light);color:var(--gold)}

.q-item-text{font-size:.78rem;color:var(--ink-2);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.q-item.is-active .q-item-text{color:var(--navy);font-weight:600}
.q-flag-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0;display:none}
.q-item.is-flagged .q-flag-dot{display:block}

/* AI Hint */
.ai-box{
  margin:10px;border-radius:var(--r);
  background:var(--gold-light);border:1px solid #e8d080;padding:13px
}
.ai-box-head{
  display:flex;align-items:center;gap:5px;
  font-size:.65rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.09em;color:var(--gold);margin-bottom:7px
}
.ai-box-text{font-size:.78rem;color:#5a3c08;line-height:1.65}
.ai-dots{display:flex;gap:3px;padding:4px 0}
.ai-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);animation:pulse 1.3s infinite ease-in-out}
.ai-dot:nth-child(2){animation-delay:.2s}
.ai-dot:nth-child(3){animation-delay:.4s}
@keyframes pulse{0%,80%,100%{transform:translateY(0);opacity:.3}40%{transform:translateY(-5px);opacity:1}}

/* ─── QUESTION PANEL ─── */
.q-panel{flex:1;overflow-y:auto;padding:28px 32px;background:var(--paper)}

.q-card{
  max-width:720px;margin:0 auto;background:var(--surface);
  border:1px solid var(--paper-3);border-radius:18px;overflow:hidden;box-shadow:var(--shadow)
}
.q-card-stripe{height:4px}
.std-32403 .q-card-stripe{background:#3d80cc}
.std-32405 .q-card-stripe{background:var(--green)}
.std-32406 .q-card-stripe{background:var(--gold)}

.q-card-body{padding:32px 36px}

.q-meta{display:flex;align-items:center;gap:8px;margin-bottom:18px}
.q-meta-badge{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:3px 10px;border-radius:20px}
.badge-num{background:var(--navy-light);color:var(--navy)}
.badge-sec{background:var(--paper);color:var(--ink-3);border:1px solid var(--paper-3)}
.q-flag-btn{
  margin-left:auto;display:flex;align-items:center;gap:5px;
  font-size:.72rem;font-weight:600;color:var(--ink-3);
  background:none;border:1.5px solid var(--paper-3);border-radius:7px;
  padding:4px 10px;cursor:pointer;transition:all .15s
}
.q-flag-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-light)}
.q-flag-btn.flagged{border-color:var(--gold);color:var(--gold);background:var(--gold-light)}
.q-emoji{font-size:2.2rem;margin-left:8px}

.q-title{font-family:'Fraunces',serif;font-size:1.45rem;font-weight:600;color:var(--ink);line-height:1.3;margin-bottom:12px}

/* Passage */
.passage{
  background:var(--paper);border:1px solid var(--paper-3);
  border-radius:11px;padding:18px 22px;margin-bottom:20px;
}
.passage-title{font-family:'Fraunces',serif;font-size:.95rem;font-weight:600;margin-bottom:10px;color:var(--ink)}
.passage-body{font-size:.85rem;color:var(--ink);line-height:1.85}

.q-scenario{font-size:.95rem;color:var(--ink-2);line-height:1.75;margin-bottom:8px}
.q-scenario strong{color:var(--ink);font-weight:600}
.q-callout{
  border-left:3px solid var(--paper-3);padding:9px 16px;
  margin:14px 0;font-size:.88rem;color:var(--ink-2);
  font-style:italic;background:var(--paper);border-radius:0 8px 8px 0
}
.q-callout strong{color:var(--ink);font-style:normal}

.q-task-label{
  font-size:.72rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.08em;color:var(--ink-3);margin:22px 0 10px;
  padding-top:20px;border-top:1px solid var(--paper-3);display:block
}

/* Inputs */
.inp-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-3);display:block;margin-bottom:7px}
.cur-wrap{position:relative;margin-bottom:16px}
.cur-sym{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-family:'DM Mono',monospace;font-size:.95rem;color:var(--ink-3);pointer-events:none}
.inp-number{
  width:100%;background:var(--paper);border:2px solid var(--paper-3);
  border-radius:10px;padding:13px 14px;font-family:'DM Mono',monospace;
  font-size:1.1rem;color:var(--ink);outline:none;transition:border-color .15s
}
.inp-number.has-prefix{padding-left:34px}
.inp-number:focus{border-color:var(--navy);background:#fff}
.inp-textarea{
  width:100%;background:var(--paper);border:2px solid var(--paper-3);
  border-radius:10px;padding:13px 14px;font-family:'DM Sans',sans-serif;
  font-size:.88rem;color:var(--ink);outline:none;resize:vertical;
  min-height:90px;line-height:1.65;transition:border-color .15s
}
.inp-textarea:focus{border-color:var(--navy);background:#fff}

.working-box{background:var(--navy-light);border:1.5px solid #c8d8ee;border-radius:10px;padding:14px;margin-top:14px}
.working-box .inp-label{color:var(--navy-mid)}
.working-box .inp-textarea{background:#fff}

/* MC */
.mc-list{display:flex;flex-direction:column;gap:9px}
.mc-opt{
  display:flex;align-items:flex-start;gap:11px;padding:13px 15px;
  border:2px solid var(--paper-3);border-radius:10px;cursor:pointer;
  background:var(--paper);transition:all .15s
}
.mc-opt:hover{border-color:var(--navy-mid);background:var(--navy-light)}
.mc-opt.sel{border-color:var(--navy);background:var(--navy-light)}
.mc-radio{
  width:19px;height:19px;border-radius:50%;border:2px solid var(--paper-3);
  flex-shrink:0;margin-top:2px;transition:all .15s;display:flex;align-items:center;justify-content:center
}
.mc-opt.sel .mc-radio{border-color:var(--navy);background:var(--navy)}
.mc-opt.sel .mc-radio::after{content:'';width:7px;height:7px;border-radius:50%;background:#fff}
.mc-opt-text{font-size:.88rem;color:var(--ink);line-height:1.5}

/* Writing rubric */
.rubric-box{background:var(--gold-light);border:1px solid #e8d080;border-radius:10px;padding:14px;margin-bottom:14px}
.rubric-title{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--gold);margin-bottom:8px}
.rubric-list{list-style:none;display:flex;flex-direction:column;gap:4px}
.rubric-item{font-size:.78rem;color:#5a3c08;display:flex;align-items:center;gap:6px}
.rubric-item::before{content:'◦';color:var(--gold);flex-shrink:0}
.wc-row{display:flex;justify-content:space-between;margin-top:6px}
.wc-label{font-size:.72rem;color:var(--ink-3)}
.wc-count{font-size:.72rem;color:var(--ink-3)}
.wc-count.ok{color:var(--green)}

/* Feedback */
.feedback{display:none;margin-top:16px;border-radius:10px;padding:13px 15px;font-size:.85rem;line-height:1.65}
.feedback.show{display:block}
.feedback.ok{background:var(--green-light);border:1px solid #a8d5bc;color:var(--green)}
.feedback.err{background:var(--red-light);border:1px solid #e5b8b2;color:var(--red)}
.feedback-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;display:flex;align-items:center;gap:5px}

/* AI writing feedback */
.ai-writing-fb{display:none;margin-top:14px;background:var(--navy-light);border:1px solid #c8d8ee;border-radius:10px;padding:14px}
.ai-writing-fb.show{display:block}
.ai-writing-fb-head{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--navy);margin-bottom:10px;display:flex;align-items:center;gap:5px}
.criterion-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid #dce8f5;font-size:.8rem}
.criterion-row:last-child{border-bottom:none}
.criterion-name{color:var(--ink-2)}
.criterion-badge{font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:20px}
.cb-met{background:var(--green-light);color:var(--green);border:1px solid #a8d5bc}
.cb-partial{background:#fff8ec;color:var(--amber);border:1px solid #e8d080}
.cb-miss{background:var(--red-light);color:var(--red);border:1px solid #e5b8b2}
.ai-overall{margin-top:10px;padding-top:10px;border-top:1px solid #dce8f5;font-size:.82rem;color:var(--ink-2);line-height:1.65}

/* Nav btns */
.q-nav-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 36px;border-top:1px solid var(--paper-3);background:var(--surface)
}
.btn-nav{
  display:flex;align-items:center;gap:6px;padding:9px 18px;
  border-radius:9px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;
  cursor:pointer;transition:all .15s;border:1.5px solid var(--paper-3);
  background:var(--surface);color:var(--ink-2)
}
.btn-nav:hover{border-color:var(--navy);color:var(--navy);background:var(--navy-light)}
.btn-nav:disabled{opacity:.3;pointer-events:none}
.btn-nav.primary{background:var(--navy);color:#fff;border-color:var(--navy)}
.btn-nav.primary:hover{background:var(--navy-mid)}
.btn-check{background:var(--gold-light);border-color:#e0c060;color:var(--gold)}
.btn-check:hover{background:#fbedc0;color:#8a6010;border-color:var(--gold)}

/* ─── RESULTS ─── */
#s-results{
  min-height:100vh;flex-direction:column;align-items:center;
  justify-content:flex-start;padding:60px 20px;background:var(--paper)
}
.results-wrap{max-width:640px;width:100%}

.results-logo{font-family:'Fraunces',serif;font-size:1.8rem;font-weight:600;color:var(--navy);text-align:center;margin-bottom:4px}
.results-logo em{font-style:italic;color:var(--gold)}

.readiness-badge{
  display:inline-flex;align-items:center;gap:7px;
  padding:10px 24px;border-radius:40px;font-size:1rem;font-weight:700;
  margin:14px auto 6px;border:2px solid;
}
.rb-ready{background:var(--green-light);color:var(--green);border-color:#a8d5bc}
.rb-developing{background:#fff8ec;color:var(--amber);border-color:#e8d080}
.rb-not-ready{background:var(--red-light);color:var(--red);border-color:#e5b8b2}
.results-sub{color:var(--ink-2);font-size:.88rem;text-align:center;margin-bottom:32px}

.res-card{background:var(--surface);border:1px solid var(--paper-3);border-radius:18px;padding:28px;margin-bottom:16px;box-shadow:var(--shadow)}

.ring-row{display:flex;align-items:center;gap:28px;margin-bottom:22px}
.ring-wrap{position:relative;width:96px;height:96px;flex-shrink:0}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-track{fill:none;stroke:var(--paper-3);stroke-width:8}
.ring-fill{fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1.1s cubic-bezier(.4,0,.2,1)}
.ring-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ring-pct{font-family:'DM Mono',monospace;font-size:1.3rem;font-weight:500;color:var(--ink)}
.ring-sub{font-size:.62rem;color:var(--ink-3);text-transform:uppercase;letter-spacing:.06em}
.ring-info-title{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:600;margin-bottom:5px}
.ring-info-sub{font-size:.82rem;color:var(--ink-2);line-height:1.65}

.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.stat-box{background:var(--paper);border-radius:10px;padding:14px;text-align:center}
.stat-val{font-family:'DM Mono',monospace;font-size:1.4rem;font-weight:500;color:var(--ink)}
.stat-lbl{font-size:.68rem;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-3);margin-top:2px}

/* Gap report */
.gap-section-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--ink-3);margin-bottom:12px}
.gap-row{
  display:flex;align-items:flex-start;gap:12px;padding:13px 0;
  border-bottom:1px solid var(--paper-3)
}
.gap-row:last-child{border-bottom:none}
.gap-icon{width:32px;height:32px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.9rem}
.gap-icon.miss{background:var(--red-light)}
.gap-icon.partial{background:#fff8ec}
.gap-icon.ok{background:var(--green-light)}
.gap-body{flex:1}
.gap-topic{font-size:.85rem;font-weight:600;color:var(--ink);margin-bottom:2px}
.gap-boost{font-size:.78rem;color:var(--ink-2);line-height:1.55}
.gap-boost strong{color:var(--navy);font-weight:600}

.res-actions{display:flex;gap:12px;margin-top:8px}
.res-btn{
  flex:1;padding:13px;border-radius:11px;font-family:'DM Sans',sans-serif;
  font-size:.88rem;font-weight:600;cursor:pointer;transition:all .15s;
  border:1.5px solid var(--paper-3);background:var(--surface);color:var(--ink-2);text-align:center
}
.res-btn:hover{border-color:var(--navy);color:var(--navy)}
.res-btn.primary{background:var(--navy);color:#fff;border-color:var(--navy)}
.res-btn.primary:hover{background:var(--navy-mid)}

/* ─── UTILS ─── */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--paper-3);border-radius:3px}
</style>
</head>
<body>

