  <div class="std-grid">
    <div class="std-tile" data-s="32403" onclick="startExam('32403')">
      <div class="std-tile-bar"></div>
      <div class="std-tile-code">US 32403</div>
      <div class="std-tile-name">Reading</div>
      <div class="std-tile-credits">5 credits</div>
      <div class="std-tile-desc">Understand authentic NZ texts — workplace notices, timetables, product labels, safety instructions.</div>
      <button class="std-tile-cta">Start Practice →</button>
    </div>
    <div class="std-tile" data-s="32405" onclick="startExam('32405')">
      <div class="std-tile-bar"></div>
      <div class="std-tile-code">US 32405</div>
      <div class="std-tile-name">Writing</div>
      <div class="std-tile-credits">5 credits</div>
      <div class="std-tile-desc">Write clearly for purpose and audience — workplace emails, community notices, instructions, short reports.</div>
      <button class="std-tile-cta">Start Practice →</button>
    </div>
    <div class="std-tile" data-s="32406" onclick="startExam('32406')">
      <div class="std-tile-bar"></div>
      <div class="std-tile-code">US 32406</div>
      <div class="std-tile-name">Numeracy</div>
      <div class="std-tile-credits">10 credits</div>
      <div class="std-tile-desc">Apply number, measurement and statistics in real NZ contexts — shopping, budgets, data, rates, GST.</div>
      <button class="std-tile-cta">Start Practice →</button>
    </div>
  </div>

  <div class="landing-foot">
    <strong>About this simulator:</strong> Questions are built from published NZQA achievement criteria for US32403, US32405 and US32406.
    All contexts are New Zealand–specific. Actual CAA questions are not released by NZQA.
  </div>
</div>

<!-- ══ EXAM ══════════════════════════════════════════════════════ -->
<div id="s-exam" class="screen">
  <header class="exam-topbar">
    <div class="topbar-left">
      <a href="index.html" style="color:rgba(255,255,255,.6);font-size:.75rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:4px;margin-right:10px">← Back</a><div class="topbar-logo">pass<em>it</em></div>
      <div class="topbar-std" id="topbar-std-label">CAA Numeracy — US32406</div>
    </div>
    <div class="topbar-right">
      <div class="timer-pill" id="timer-pill">
        <svg class="timer-icon" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="timer-val" id="timer-val">40:00</span>
      </div>
      <button class="submit-btn" onclick="submitExam()">Submit Exam</button>
    </div>
  </header>

  <div class="exam-body">
    <aside class="sidebar">
