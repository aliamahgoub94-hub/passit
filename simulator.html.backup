      <div class="ai-box">
        <div class="ai-box-head">✦ AI Hint</div>
        <div class="ai-box-text" id="ai-hint">Choose a question to see a targeted hint.</div>
      </div>
    </aside>

    <main class="q-panel" id="q-panel"></main>
  </div>
</div>

