<script>
// ══ QUESTION BANK ═════════════════════════════════════════════════════════

const BANK = {
  '32406': [
    { id:'n01',sec:'Shopping',emoji:'🍌',title:'Calculating at the Supermarket',
      scenario:'At Countdown, bananas cost <strong>$3.29 per kilogram</strong>.',
      callout:'You pick up a bunch that weighs <strong>685 grams</strong>.',
      type:'currency',task:'How much do you pay for the bananas? Round to the nearest cent.',
      answer:2.25,tol:.02,topic:'Unit conversion & multiplication',
      hint:'Convert grams to kilograms first (÷1000), then multiply by the price per kg.',
      explain:'685g ÷ 1000 = 0.685kg. 0.685 × $3.29 = $2.254 → <strong>$2.25</strong>',
      boost:'Practice: convert any weight in grams to kg, then multiply by a price per kg.' },
    { id:'n02',sec:'Shopping',emoji:'🧥',title:'Sale Price',
      scenario:'A jacket at Farmers costs <strong>$129.99</strong>.',callout:"It's on sale for <strong>30% off</strong>.",
      type:'currency',task:'What is the sale price?',
      answer:90.99,tol:.02,topic:'Percentages',
      hint:'Find 30% of $129.99 (multiply by 0.30), then subtract.',
      explain:'30% of $129.99 = $39.00. $129.99 − $39.00 = <strong>$90.99</strong>',
      boost:'Practise finding percentage discounts: multiply original by (1 − discount rate).' },
    { id:'n03',sec:'Budgeting',emoji:'💰',title:"Hemi's Weekly Budget",
      scenario:'Hemi earns <strong>$680/week</strong> after tax.',
      callout:'Expenses: rent $220, food $95, transport $45, phone $25.',
      type:'currency',task:'How much is left after all expenses?',
      answer:295,tol:0,topic:'Addition & subtraction',
      hint:'Add all expenses together, then subtract from $680.',
      explain:'Total expenses: $385. $680 − $385 = <strong>$295</strong>',
      boost:'Write out all expenses in a list and add them before subtracting — avoid skipping steps.' },
    { id:'n04',sec:'Measurement',emoji:'🏠',title:'Carpet Cost',
      scenario:'A bedroom is <strong>4.2 m long</strong> and <strong>3.5 m wide</strong>.',callout:'Carpet costs <strong>$28/m²</strong>.',
      type:'currency',task:'Total cost to carpet the room?',
      answer:411.6,tol:.05,topic:'Area & rates',
      hint:'Calculate area first (length × width), then multiply by cost per m².',
      explain:'Area = 4.2 × 3.5 = 14.7 m². 14.7 × $28 = <strong>$411.60</strong>',
      boost:'Remember: area of a rectangle = length × width. Always check your units.' },
    { id:'n05',sec:'Data',emoji:'📊',title:'Survey Results',
      scenario:'120 students chose a preferred sport.',callout:'Rugby 35%, Netball 25%, Football 20%, Basketball 12%, Other 8%.',
      type:'number',task:'How many students chose Rugby or Netball combined?',
      answer:72,tol:0,topic:'Percentages & whole numbers',
      hint:'Add the two percentages, then find that % of 120.',
      explain:'35% + 25% = 60%. 0.60 × 120 = <strong>72 students</strong>',
      boost:'To find a percentage of a number: convert % to a decimal (÷100), then multiply.' },
    { id:'n06',sec:'Time',emoji:'🚌',title:'Journey Planning',
      scenario:'Aroha must be at work by <strong>8:45 am</strong>.',callout:'Bus takes 35 min. She needs 15 min once she arrives.',
      type:'mc',task:'Latest time to leave home?',
      options:['7:45 am','7:55 am','8:00 am','7:50 am'],answer:'7:55 am',topic:'Time calculations',
      hint:'Work backwards from 8:45 am. Total time needed: 35 + 15 = 50 minutes.',
      explain:'8:45 am − 50 min = <strong>7:55 am</strong>',
      boost:'For time problems: identify the finish time and work backwards, adding each step.' },
    { id:'n07',sec:'Rates',emoji:'⛽',title:'Petrol for a Road Trip',
      scenario:"Petrol is <strong>$2.89/litre</strong>. Tama's car uses <strong>8.5L per 100km</strong>.",callout:'He drives 240 km.',
      type:'currency',task:"Total petrol cost? Round to the nearest cent.",
      answer:58.94,tol:.05,topic:'Rates & multi-step calculation',
      hint:'Step 1: find litres needed (8.5 × 240 ÷ 100). Step 2: multiply litres × price.',
      explain:'Litres: 8.5×240÷100 = 20.4L. Cost: 20.4 × $2.89 = <strong>$58.96</strong>',
      boost:'Multi-step rate problems: write out each step before calculating.' },
    { id:'n08',sec:'GST',emoji:'🔧',title:'Mechanic Invoice + GST',
      scenario:'Service charge: <strong>$340 + GST</strong>.',callout:'NZ GST is <strong>15%</strong>.',
      type:'currency',task:'Total amount payable including GST?',
      answer:391,tol:.01,topic:'GST & percentages',
      hint:'GST = $340 × 0.15. Add to the original amount.',
      explain:'$340 × 0.15 = $51. $340 + $51 = <strong>$391.00</strong>',
      boost:'Quick GST shortcut: multiply the pre-GST amount by 1.15.' },
    { id:'n09',sec:'Fractions',emoji:'🍕',title:'Splitting a Dinner Bill',
      scenario:'Five friends share a $143.50 bill.',callout:'They add a <strong>10% tip</strong> on top.',
      type:'currency',task:"Each person's share (including tip)?",
      answer:31.57,tol:.02,topic:'Multi-step: percentages & division',
      hint:'First find the total with tip (×1.10), then divide by 5.',
      explain:'$143.50 × 1.10 = $157.85. ÷5 = <strong>$31.57</strong>',
      boost:'Always complete all operations in order — adding the tip before dividing is critical.' },
    { id:'n10',sec:'Speed',emoji:'🚗',title:'Auckland to Hamilton',
      scenario:'Distance: <strong>128 km</strong>.',callout:'Average speed: <strong>96 km/h</strong>.',
      type:'mc',task:'Approximate travel time?',
      options:['1 hr 10 min','1 hr 20 min','1 hr 45 min','2 hrs'],answer:'1 hr 20 min',topic:'Speed, distance, time',
      hint:'Time = Distance ÷ Speed. Convert the decimal to minutes (×60).',
      explain:'128 ÷ 96 = 1.333… hrs = 1 hr 20 min',
      boost:'Speed formula triangle: Distance = Speed × Time. Cover what you want to find.' },
  ],
  '32403': [
    { id:'r01',sec:'Workplace',emoji:'📋',title:'Fire Drill Notice',
      passageTitle:'STAFF NOTICE — Fire Evacuation Drill',
      passage:`All staff must complete a fire evacuation drill on Thursday 15 August at 2:00 pm. When the alarm sounds, stop all work immediately and exit via the nearest fire door. Do not use lifts. Assemble at the car park on Trent Street.\n\nStaff working from home that day must notify their manager before 9 am. Fire warden: Sarah Kim (ext. 204).`,
      type:'mc',task:'Where should staff assemble during the drill?',
      options:['Main entrance','Car park on Trent Street','Fire exit Level 2','Outside staff room'],
      answer:'Car park on Trent Street',topic:'Locating specific information',
      hint:"Find the word 'Assemble' in the notice.",
      explain:"The notice states: 'Assemble at the car park on Trent Street.'",
      boost:"When locating information: scan for a key word from the question (here: 'assemble')." },
    { id:'r02',sec:'Workplace',emoji:'📋',title:'Working from Home Rule',
      passageTitle:'STAFF NOTICE — Fire Evacuation Drill',
      passage:`All staff must complete a fire evacuation drill on Thursday 15 August at 2:00 pm. When the alarm sounds, stop all work immediately and exit via the nearest fire door. Do not use lifts. Assemble at the car park on Trent Street.\n\nStaff working from home that day must notify their manager before 9 am. Fire warden: Sarah Kim (ext. 204).`,
      type:'mc',task:'What must work-from-home staff do on that day?',
      options:['Come in for the drill','Notify manager before 9 am','Call ext. 204','Complete drill online'],
      answer:'Notify manager before 9 am',topic:'Locating specific information',
      hint:"Find the sentence that mentions 'working from home'.",
      explain:"The notice states: 'Staff working from home that day must notify their manager before 9 am.'",
      boost:'Read each option carefully — some are plausible but appear nowhere in the text.' },
    { id:'r03',sec:'Timetables',emoji:'🚌',title:'Catching the Right Bus',
      passageTitle:'Metro Bus — Route 22 Weekday Timetable',
      passage:`Central Station:   6:15  7:00  7:45  8:30  9:15\nKings Ave:         6:22  7:07  7:52  8:37  9:22\nRainbow Road:      6:31  7:16  8:01  8:46  9:31\nAirport Terminal:  6:48  7:33  8:18  9:03  9:48\n\nNote: Buses do not run on public holidays. Journey time approx. 33 minutes.`,
      type:'mc',task:'Latest bus from Central to arrive at Airport Terminal before 8:20 am?',
      options:['6:15 bus','7:00 bus','7:45 bus','8:30 bus'],answer:'7:45 bus',topic:'Reading timetables',
      hint:"Find all arrival times at Airport Terminal before 8:20 am, then pick the latest departure.",
      explain:'7:45 bus arrives 8:18 am (before 8:20). 8:30 bus arrives 9:03 am (too late).',
      boost:'For timetable questions: find the arrival column first, then trace back to the departure.' },
    { id:'r04',sec:'Product Labels',emoji:'🧺',title:'Laundry Powder Directions',
      passageTitle:'Laundry Powder — Directions for Use',
      passage:`Front loader: Use 60 ml per load. For heavily soiled items, increase to 80 ml.\nTop loader: Use 100 ml per load.\nHandwashing: Dissolve 15 ml in warm water before adding clothes.\n\n⚠ CAUTION: Keep out of reach of children. Do not mix with bleach. If swallowed, seek medical advice immediately.\nStorage: Store in a cool, dry place away from direct sunlight.`,
      type:'mc',task:'Amount for heavily soiled items in a front loader?',
      options:['60 ml','80 ml','100 ml','15 ml'],answer:'80 ml',topic:'Following instructions',
      hint:"Find 'Front loader' and look for 'heavily soiled'.",
      explain:"The label states: 'For heavily soiled items, increase to 80 ml.'",
      boost:"'Increase to' means use that amount — not 60 ml + 80 ml." },
    { id:'r05',sec:'Forms',emoji:'📚',title:'Library Membership',
      passageTitle:'Selwyn Library — New Member Application',
      passage:`Membership is free for all Selwyn District residents. To join:\n• Proof of current address (utility bill, bank statement, or letter dated within 3 months)\n• Photo ID (driver's licence, passport, or 18+ card)\n• Complete this form and return to the front desk\n\nMembers may borrow up to 8 items. Items kept for 3 weeks; renewed twice online. Overdue fines: 20c per item per day.`,
      type:'mc',task:'How many times can a borrowed item be renewed?',
      options:['Once','Twice','Three times','Cannot be renewed'],answer:'Twice',topic:'Locating specific information',
      hint:"Search for the word 'renewed' in the text.",
      explain:"The form states: 'Items may be kept for 3 weeks and renewed twice online.'",
      boost:'Underline or highlight key facts when reading — especially numbers and limits.' },
    { id:'r06',sec:'Health & Safety',emoji:'⚠️',title:'Chemical Safety Notice',
      passageTitle:'Cleaning Fluid X4 — Safety Data Sheet',
      passage:`HAZARD: Irritant. Avoid contact with skin and eyes.\n\nFIRST AID:\n• Skin contact: Rinse with water for at least 15 minutes.\n• Eye contact: Flush with water for 20 minutes. Seek medical attention immediately.\n• If swallowed: Do NOT induce vomiting. Call Poison Control: 0800 764 766.\n\nSTORAGE: Keep container sealed in a ventilated area. Do not store near food.\nPPE: Chemical-resistant gloves and safety glasses required.`,
      type:'mc',task:'If the fluid gets in someone\'s eyes, what should be done FIRST?',
      options:['Call Poison Control','Flush with water for 20 minutes','Rinse with water for 15 minutes','Seek medical attention'],
      answer:'Flush with water for 20 minutes',topic:'Sequencing / following instructions',
      hint:"Find 'Eye contact' and read the first step listed.",
      explain:"Eye contact: 'Flush with water for 20 minutes' — this comes before seeking medical attention.",
      boost:"Safety data sheets list steps in order. The first bullet point is always the first action." },
  ],
  '32405': [
    { id:'w01',sec:'Workplace',emoji:'☕',title:'Broken Coffee Machine',
      scenario:'You work at a café. Your manager Sara Chen is away.',callout:'The coffee machine broke this morning (Monday). Email Sara.',
      type:'writing',task:"Write a short workplace email to Sara. Include: what happened, when, and what you need her to do.",
      wordMin:50,wordMax:130,topic:'Workplace email',
      rubric:['Subject line present','Appropriate greeting (e.g. Hi Sara)','Clearly states what happened','States when it happened','Includes a clear request or action needed','Professional sign-off','Appropriate workplace tone'],
      hint:'Structure: Subject line → Greeting → Problem (what + when) → What you need → Sign-off.',
      explain:'A strong response includes a subject line ("Coffee machine broken"), names the problem and timing, asks what to do next, and signs off professionally.',
      boost:'Before writing: note the 5 things to include. Check each one off as you write.' },
    { id:'w02',sec:'Notices',emoji:'🌿',title:'Community Clean-Up',
      scenario:'Organising a neighbourhood clean-up day.',callout:'Sat 23 Aug, 9 am. Elm Street Reserve. Bring gloves, wear old clothes.',
      type:'writing',task:'Write a noticeboard notice inviting neighbours. Include all key information.',
      wordMin:60,wordMax:140,topic:'Community notice',
      rubric:['Clear heading or title','Date included','Time included','Location included','What to bring or wear mentioned','Friendly, inviting tone','Easy to read'],
      hint:'A good notice answers: Who? What? When? Where? What to bring?',
      explain:'Effective notices have a bold heading, answer all the key questions, and use an inviting tone that makes people want to come.',
      boost:"Read your notice aloud. If you'd want to come, it's probably working." },
    { id:'w03',sec:'Instructions',emoji:'🥫',title:'Food Bank Sorting',
      scenario:'Writing instructions for a new food bank volunteer.',callout:'They must sort donations into: canned goods, dry goods (pasta/rice/cereal), and items needing refrigeration.',
      type:'writing',task:'Write clear step-by-step instructions for sorting the donations.',
      wordMin:70,wordMax:160,topic:'Sequential instructions',
      rubric:['Numbered steps or sequence words used','All three categories named','Clear direction for each category','Simple, direct language','Logical order','Complete enough to follow independently'],
      hint:'Use: First… Then… Next… Finally. Name all three categories by the end.',
      explain:'Good instructions are numbered, name all categories explicitly, and give enough detail that someone could follow them without asking questions.',
      boost:"Read your instructions as if you've never seen the job before. Anything confusing? Fix it." },
    { id:'w04',sec:'Reports',emoji:'⚠️',title:'Forklift Near-Miss Report',
      scenario:'You manage a warehouse team. Two forklift near-misses occurred last week.',callout:'Report to H&S coordinator before Friday.',
      type:'writing',task:'Write a short report describing what happened and recommending one preventive action.',
      wordMin:70,wordMax:170,topic:'Short workplace report',
      rubric:['States the problem clearly','Mentions number of incidents and timeframe','Professional, factual tone','Includes a specific recommendation','Appropriate for H&S audience','Sufficient detail'],
      hint:'Structure: What happened → When/how often → Why it matters → One specific recommendation.',
      explain:'Strong reports state facts clearly, avoid emotional language, and end with a specific actionable recommendation — not just "be more careful".',
      boost:"Your recommendation must be specific. 'Review forklift routes' is better than 'improve safety'." },
    { id:'w05',sec:'Text Messages',emoji:'📱',title:'Rescheduling a Job Interview',
      scenario:'Job interview: 2 pm tomorrow, City HR Services, 45 Queen St.',callout:"Transit strike — your bus isn't running that route.",
      type:'writing',task:"Write a professional text to the HR manager (Ms Patel) asking to change the time or format.",
      wordMin:35,wordMax:90,topic:'Professional communication',
      rubric:['Polite, professional tone','Explains the problem briefly','Apologises for short notice','Offers a solution or asks for options','Appropriate for a job applicant context','Concise but complete'],
      hint:'Keep it brief: problem → apology → solution. Texts can be short and still be professional.',
      explain:'A strong text briefly explains the issue, apologises for short notice, and offers a concrete alternative (later time, phone or video call).',
      boost:"In professional texts: one sentence per idea. Never use slang." },
  ],
};

// ── STATE ────────────────────────────────────────────────────────────────
const S = {
  std: null, questions: [], idx: 0,
  answers: {}, flags: new Set(),
  secsLeft: 0, timer: null, elapsed: 0,
  hintCache: {}
};

const STD_TIMES = { '32406': 40*60, '32403': 30*60, '32405': 30*60 };
const STD_LABELS = { '32406':'CAA Numeracy — US32406', '32403':'CAA Reading — US32403', '32405':'CAA Writing — US32405' };
const STD_NAMES = { '32406':'CAA Numeracy', '32403':'CAA Reading', '32405':'CAA Writing' };

// ── HELPERS ──────────────────────────────────────────────────────────────
function show(id){ document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function fmtTime(s){ const m=Math.floor(s/60),ss=String(s%60).padStart(2,'0'); return `${m}:${ss}`; }
function wordCount(str){ return str.trim().split(/\s+/).filter(Boolean).length; }

// ── START ────────────────────────────────────────────────────────────────
function startExam(std){
  S.std = std;
  S.questions = [...BANK[std]].sort(()=>Math.random()-.5).slice(0,6);
  S.idx = 0; S.answers = {}; S.flags = new Set(); S.elapsed = 0; S.hintCache = {};
  S.secsLeft = STD_TIMES[std];
  document.getElementById('topbar-std-label').textContent = STD_LABELS[std];
  buildNav(); renderQ(0); startTimer(); show('s-exam');
}

function startTimer(){
  clearInterval(S.timer);
  S.timer = setInterval(()=>{
    S.elapsed++;
    S.secsLeft = Math.max(0, STD_TIMES[S.std] - S.elapsed);
    const el = document.getElementById('timer-val');
    const pill = document.getElementById('timer-pill');
    el.textContent = fmtTime(S.secsLeft);
    pill.className = 'timer-pill' + (S.secsLeft <= 300 ? ' danger' : S.secsLeft <= 600 ? ' warn' : '');
    if(S.secsLeft === 0){ clearInterval(S.timer); submitExam(); }
  }, 1000);
}

// ── NAV ──────────────────────────────────────────────────────────────────
function buildNav(){
  const nav = document.getElementById('q-list');
  nav.innerHTML = '';
  S.questions.forEach((q,i)=>{
    const d = document.createElement('div');
    d.className = 'q-item'; d.id = `qi-${i}`;
    d.innerHTML = `<div class="q-item-num" id="qn-${i}">${i+1}</div><span class="q-item-text">${q.title}</span><div class="q-flag-dot"></div>`;
    d.onclick = ()=>renderQ(i);
    nav.appendChild(d);
  });
  updateNav();
}

function updateNav(){
  const answered = S.questions.filter(q=>S.answers[q.id]!==undefined && S.answers[q.id]!=='').length;
  document.getElementById('sb-progress').textContent = `${answered}/${S.questions.length}`;
  S.questions.forEach((q,i)=>{
    const item = document.getElementById(`qi-${i}`);
    const num = document.getElementById(`qn-${i}`);
    if(!item) return;
    const isActive = i===S.idx;
    const isAnswered = S.answers[q.id]!==undefined && S.answers[q.id]!=='';
    const isFlagged = S.flags.has(q.id);
    item.className = ['q-item', isActive&&'is-active', isAnswered&&'is-answered', isFlagged&&'is-flagged'].filter(Boolean).join(' ');
  });
  const q = S.questions[S.idx];
  if(q) document.getElementById('sb-section').textContent = q.sec;
}

// ── RENDER ───────────────────────────────────────────────────────────────
function renderQ(idx){
  S.idx = idx;
  const q = S.questions[idx];
  const panel = document.getElementById('q-panel');
  const sa = S.answers[q.id] ?? '';
  const isFlagged = S.flags.has(q.id);

  // Task input HTML
  let inputHTML = '';
  if(q.type==='currency'){
    inputHTML = `
      <label class="inp-label">Your Answer ($)</label>
      <div class="cur-wrap">
        <span class="cur-sym">$</span>
        <input type="number" step="0.01" min="0" class="inp-number has-prefix" id="ans-inp" placeholder="0.00" value="${sa}" oninput="saveAns()">
      </div>
      <div class="working-box">
        <label class="inp-label">Show your working (optional)</label>
        <textarea class="inp-textarea" id="work-inp" rows="3" placeholder="Write your steps here…" oninput="saveWork()">${S.answers[q.id+'_w']||''}</textarea>
      </div>`;
  } else if(q.type==='number'){
    inputHTML = `
      <label class="inp-label">Your Answer</label>
      <input type="number" class="inp-number" id="ans-inp" placeholder="Enter a number" value="${sa}" oninput="saveAns()" style="margin-bottom:14px">
      <div class="working-box">
        <label class="inp-label">Show your working (optional)</label>
        <textarea class="inp-textarea" id="work-inp" rows="3" placeholder="Write your steps here…" oninput="saveWork()">${S.answers[q.id+'_w']||''}</textarea>
      </div>`;
  } else if(q.type==='mc'){
    inputHTML = `<div class="mc-list">` +
      q.options.map(opt=>`<div class="mc-opt ${sa===opt?'sel':''}" onclick="pickMC(this,'${opt.replace(/'/g,"\\'")}')"><div class="mc-radio"></div><span class="mc-opt-text">${opt}</span></div>`).join('') +
      `</div>`;
  } else if(q.type==='writing'){
    const wc = sa ? wordCount(sa) : 0;
    inputHTML = `
      <div class="rubric-box">
        <div class="rubric-title">Assessment criteria</div>
        <ul class="rubric-list">${q.rubric.map(r=>`<li class="rubric-item">${r}</li>`).join('')}</ul>
      </div>
      <label class="inp-label">Your Response</label>
      <textarea class="inp-textarea" id="ans-inp" rows="9" placeholder="Write your response here…" oninput="saveAns();updateWC()" style="min-height:170px">${sa}</textarea>
      <div class="wc-row">
        <span class="wc-label">${q.wordMin}–${q.wordMax} words</span>
        <span class="wc-count ${wc>=q.wordMin&&wc<=q.wordMax?'ok':''}" id="wc-display">${wc} words</span>
      </div>
      <div class="ai-writing-fb" id="ai-write-fb">
        <div class="ai-writing-fb-head">✦ AI Marking</div>
        <div id="ai-criteria-rows"></div>
        <div class="ai-overall" id="ai-overall"></div>
      </div>`;
  }

  // Passage
  const passageHTML = q.passage ? `
    <div class="passage">
      <div class="passage-title">${q.passageTitle||'Read the following text'}</div>
      <div class="passage-body">${q.passage.replace(/\n/g,'<br>')}</div>
    </div>` : '';

  panel.innerHTML = `
    <div class="std-${S.std}">
      <div class="q-card">
        <div class="q-card-stripe"></div>
        <div class="q-card-body">
          <div class="q-meta">
            <span class="q-meta-badge badge-num">Question ${idx+1} of ${S.questions.length}</span>
            <span class="q-meta-badge badge-sec">${q.sec}</span>
            <button class="q-flag-btn ${isFlagged?'flagged':''}" id="flag-btn" onclick="toggleFlag()">
              ${isFlagged?'⚑ Flagged':'⚐ Flag for review'}
            </button>
            <span class="q-emoji">${q.emoji}</span>
          </div>
          <h2 class="q-title">${q.title}</h2>
          ${passageHTML}
          ${q.scenario?`<p class="q-scenario">${q.scenario}</p>`:''}
          ${q.callout?`<div class="q-callout">${q.callout}</div>`:''}
          <span class="q-task-label">${q.task}</span>
          ${inputHTML}
          <div class="feedback" id="feedback"></div>
        </div>
        <div class="q-nav-row">
          <button class="btn-nav" onclick="goQ(${idx-1})" ${idx===0?'disabled':''}>← Previous</button>
          <button class="btn-nav btn-check" onclick="checkAnswer()">✦ Check Answer</button>
          <button class="btn-nav primary" onclick="goQ(${idx+1})" ${idx===S.questions.length-1?'disabled':''}>Next →</button>
        </div>
      </div>
    </div>`;

  updateNav();
  loadHint(q);
  panel.scrollTop = 0;
}

function goQ(i){ if(i>=0 && i<S.questions.length) renderQ(i); }

function toggleFlag(){
  const q = S.questions[S.idx];
  if(S.flags.has(q.id)) S.flags.delete(q.id); else S.flags.add(q.id);
  const btn = document.getElementById('flag-btn');
  if(btn){ btn.className='q-flag-btn '+(S.flags.has(q.id)?'flagged':''); btn.textContent=S.flags.has(q.id)?'⚑ Flagged':'⚐ Flag for review'; }
  updateNav();
}

// ── ANSWER SAVE ──────────────────────────────────────────────────────────
function saveAns(){
  const q=S.questions[S.idx]; const inp=document.getElementById('ans-inp'); if(!inp)return;
  const v=inp.value.trim();
  S.answers[q.id] = (q.type==='currency'||q.type==='number') ? (v?parseFloat(v):'') : v;
  updateNav();
}
function saveWork(){ const q=S.questions[S.idx]; const inp=document.getElementById('work-inp'); if(inp)S.answers[q.id+'_w']=inp.value; }
function updateWC(){
  const inp=document.getElementById('ans-inp'); const el=document.getElementById('wc-display'); if(!inp||!el)return;
  const q=S.questions[S.idx]; const wc=wordCount(inp.value);
  el.textContent=`${wc} words`; el.className='wc-count '+(wc>=q.wordMin&&wc<=q.wordMax?'ok':'');
}
function pickMC(el,val){
  document.querySelectorAll('.mc-opt').forEach(o=>o.classList.remove('sel')); el.classList.add('sel');
  S.answers[S.questions[S.idx].id]=val; updateNav();
}

// ── CHECK ────────────────────────────────────────────────────────────────
async function checkAnswer(){
  saveAns();
  const q=S.questions[S.idx]; const ua=S.answers[q.id]; const fb=document.getElementById('feedback');
  if(ua===undefined||ua===''){
    fb.className='feedback show err'; fb.innerHTML='<div class="feedback-label">⚠ No answer yet</div>Enter your answer before checking.'; return;
  }
  if(q.type==='writing'){
    const wc=wordCount(String(ua));
    if(wc<q.wordMin){
      fb.className='feedback show err'; fb.innerHTML=`<div class="feedback-label">✗ Too short (${wc} words)</div>Aim for at least ${q.wordMin} words. Tip: ${q.hint}`; return;
    }
    // AI marking
    fb.className='feedback show ok'; fb.innerHTML='<div class="feedback-label">✦ Sending to AI marker…</div>';
    await markWritingWithAI(q, String(ua));
    return;
  }
  let correct=false;
  if(q.type==='mc') correct=ua===q.answer;
  else correct=Math.abs(Number(ua)-Number(q.answer))<=(q.tol??0);

  fb.className=`feedback show ${correct?'ok':'err'}`;
  if(correct) fb.innerHTML=`<div class="feedback-label">✓ Correct!</div>${q.explain}`;
  else{
    const disp=q.type==='currency'?`$${Number(q.answer).toFixed(2)}`:q.answer;
    fb.innerHTML=`<div class="feedback-label">✗ Not quite — correct answer: ${disp}</div>${q.explain}`;
  }
}

// ── AI MARKING (Writing) ─────────────────────────────────────────────────
async function markWritingWithAI(q, response){
  const fb = document.getElementById('feedback');
  const aiFb = document.getElementById('ai-write-fb');
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:600,
        system:`You are an NCEA NZ writing assessor. Given a student's response and a rubric, return ONLY valid JSON in this exact format:
{"criteria":[{"name":"criterion name","verdict":"met"|"partial"|"missing","note":"one short sentence max"}],"overall":"One sentence overall feedback, specific and constructive."}
Be honest but encouraging. Use NZ English.`,
        messages:[{role:'user',content:`Task: ${q.task}\nRubric criteria: ${q.rubric.join(', ')}\nStudent response:\n${response}`}]
      })
    });
    const data = await res.json();
    const text = data?.content?.[0]?.text ?? '';
    const json = JSON.parse(text.replace(/```json|```/g,'').trim());

    // Render criteria rows
    const rows = json.criteria.map(c=>{
      const cls = c.verdict==='met'?'cb-met':c.verdict==='partial'?'cb-partial':'cb-miss';
      const label = c.verdict==='met'?'✓ Met':c.verdict==='partial'?'~ Partial':'✗ Missing';
      return `<div class="criterion-row"><span class="criterion-name">${c.name}</span><span class="criterion-badge ${cls}">${label}</span></div>${c.note?`<div style="font-size:.75rem;color:var(--ink-3);padding:3px 0 6px">${c.note}</div>`:''}`;
    }).join('');

    if(aiFb){
      aiFb.className='ai-writing-fb show';
      document.getElementById('ai-criteria-rows').innerHTML=rows;
      document.getElementById('ai-overall').innerHTML=`<strong>Overall:</strong> ${json.overall}`;
    }
    fb.className='feedback show ok';
    fb.innerHTML=`<div class="feedback-label">✓ AI marking complete</div>See the detailed breakdown below.`;
  } catch(e){
    fb.className='feedback show ok';
    fb.innerHTML=`<div class="feedback-label">✓ Response submitted (${wordCount(response)} words)</div>${q.explain}<br><br>Check your response against the rubric above.`;
  }
}

// ── AI HINT ──────────────────────────────────────────────────────────────
async function loadHint(q){
  const el=document.getElementById('ai-hint'); if(!el)return;
  if(S.hintCache[q.id]){el.textContent=S.hintCache[q.id];return;}
  if(q.hint){S.hintCache[q.id]=q.hint;el.textContent=q.hint;return;}
  el.innerHTML='<div class="ai-dots"><div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div></div>';
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:100,system:'One short NZ NCEA coaching hint (max 2 sentences). Point to method, not answer. Start directly.',messages:[{role:'user',content:`${q.task} Context: ${(q.scenario||'')+(q.callout||'')}`.replace(/<[^>]+>/g,'')}]})});
    const d=await r.json(); const h=d?.content?.[0]?.text??q.hint??'Think step by step.';
    S.hintCache[q.id]=h; el.textContent=h;
  }catch{el.textContent=q.hint??'Think step by step.';}
}

// ── SUBMIT ───────────────────────────────────────────────────────────────
function submitExam(){
  clearInterval(S.timer);
  const qs=S.questions; let correct=0,scoreable=0;
  qs.forEach(q=>{
    if(q.type==='writing')return; scoreable++;
    const ua=S.answers[q.id]; if(ua===undefined||ua==='')return;
    if(q.type==='mc'){if(ua===q.answer)correct++;}
    else{if(Math.abs(Number(ua)-Number(q.answer))<=(q.tol??0))correct++;}
  });
  const pct = scoreable>0?Math.round(correct/scoreable*100):0;
  const elapsed = S.elapsed;
  const m=Math.floor(elapsed/60), ss=String(elapsed%60).padStart(2,'0');

  // Readiness level
  let rdLabel,rdClass,rdSub;
  if(pct>=80){rdLabel='✓ CAA-Ready';rdClass='rb-ready';rdSub='Strong performance — you\'re on track to achieve this standard.';}
  else if(pct>=55){rdLabel='◑ Developing';rdClass='rb-developing';rdSub='You\'re building the right skills. Target the gaps below.';}
  else{rdLabel='✗ Not Yet Ready';rdClass='rb-not-ready';rdSub='Keep practising — the gap report below shows exactly where to focus.';}

  document.getElementById('readiness-badge').className=`readiness-badge ${rdClass}`;
  document.getElementById('readiness-badge').textContent=rdLabel;
  document.getElementById('results-sub').textContent=rdSub;
  document.getElementById('res-std-name').textContent=STD_NAMES[S.std];
  document.getElementById('ring-pct').textContent=scoreable>0?`${pct}%`:'N/A';
  document.getElementById('st-correct').textContent=scoreable>0?`${correct}/${scoreable}`:'—';
  document.getElementById('st-total').textContent=qs.length;
  document.getElementById('st-time').textContent=`${m}:${ss}`;
  document.getElementById('res-breakdown').textContent=S.std==='32405'
    ?'Writing tasks are AI-marked — review your criterion feedback above.'
    :pct>=80?`${correct} of ${scoreable} correct — excellent work.`:`${correct} of ${scoreable} correct — see gap report below.`;

  // Animate ring
  setTimeout(()=>{
    const fill=document.getElementById('ring-fill');
    fill.style.stroke=pct>=80?'var(--green)':pct>=55?'var(--amber)':'var(--red)';
    fill.style.strokeDashoffset=scoreable>0?String(264-(264*pct/100)):'264';
  },100);

  // Gap report
  buildGapReport(qs);
  show('s-results');
  window.scrollTo(0,0);
}

function buildGapReport(qs){
  const list=document.getElementById('gap-list'); list.innerHTML='';
  qs.forEach(q=>{
    let status='ok';
    if(q.type==='writing'){
      const ua=S.answers[q.id];
      status=(!ua||wordCount(String(ua))<(q.wordMin||40))?'miss':'ok';
    } else {
      const ua=S.answers[q.id];
      if(ua===undefined||ua==='') status='miss';
      else if(q.type==='mc') status=ua===q.answer?'ok':'miss';
      else status=Math.abs(Number(ua)-Number(q.answer))<=(q.tol??0)?'ok':'miss';
    }
    const icons={ok:'✓',miss:'✗',partial:'~'};
    const row=document.createElement('div'); row.className='gap-row';
    row.innerHTML=`
      <div class="gap-icon ${status}">${icons[status]}</div>
      <div class="gap-body">
        <div class="gap-topic">${q.topic}</div>
        <div class="gap-boost">${status==='ok'
          ?`<strong>Strong.</strong> ${q.boost}`
          :`<strong>Boost task:</strong> ${q.boost}`}</div>
      </div>`;
    list.appendChild(row);
  });
}

function retryExam(){ startExam(S.std); }
function goHome(){
  clearInterval(S.timer);
  window.location='index.html';
}
</script>
</body>
</html>
